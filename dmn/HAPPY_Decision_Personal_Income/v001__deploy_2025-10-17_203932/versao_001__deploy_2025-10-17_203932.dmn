  <decision id="HAPPY_Decision_Personal_Income" name="HAPPY_Decision_Personal_Income" camunda:historyTimeToLive="30">
    <decisionTable id="DecisionTable_0r12t6h" hitPolicy="FIRST">
      <input id="InputClause_0ah9vnq" label="Base Margin Income Ratio" biodi:width="192" camunda:inputVariable="base_margin_income_ratio">
        <inputExpression id="LiteralExpression_1qns5an" typeRef="double">
