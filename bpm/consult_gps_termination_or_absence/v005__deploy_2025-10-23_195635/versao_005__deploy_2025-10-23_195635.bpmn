    <bpmn:serviceTask id="Activity_16s3vp1" name="Consult contract termination GPS" camunda:asyncAfter="true" camunda:type="external" camunda:topic="RestGetApi">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="url">https://portalws.gpssa.com.br/srh_api/api/externo/existe-rescisao?cpf=${document_number}</camunda:inputParameter>
          <camunda:inputParameter name="headers">{
    "api-key": "a8916e23-3d9c-4332-8460-b4ee60107d05",
    "Accept": "application/json"
}</camunda:inputParameter>
