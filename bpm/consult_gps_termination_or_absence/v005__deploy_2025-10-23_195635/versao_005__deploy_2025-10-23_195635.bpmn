      <bpmn:incoming>Flow_1gu790l</bpmn:incoming>
      <bpmn:outgoing>Flow_1sm7jvf</bpmn:outgoing>
      <bpmn:script>const response_termination = JSON.parse(execution.getVariable("response_termination"));
execution.setVariable("has_gps_termination", response_termination.existe_rescisao);</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1sm7jvf" sourceRef="Proccess_Response" targetRef="Gateway_1jcipyf" />
