    <bpmn:serviceTask id="Consulta_NEXAIQ_Cadastro_PJ" name="Consulta NEXAIQ Cadastro PJ" camunda:asyncAfter="true" camunda:type="external" camunda:topic="RestPostApi">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="url">/consulta/cadastro/v1/pj</camunda:inputParameter>
          <camunda:inputParameter name="body">{
  "cnpj": "${company_document_number}"
}</camunda:inputParameter>
          <camunda:inputParameter name="authenticate">{
    "user": "nexaiq_client_id",
    "password": "nexaiq_client_secret",
    "grant_type": "client_credentials",
    "path": "nexaiq_auth_url"
}</camunda:inputParameter>
          <camunda:inputParameter name="timeout">60000</camunda:inputParameter>
          <camunda:inputParameter name="process">Consulta_NEXAIQ_Cadastro_PJ</camunda:inputParameter>
          <camunda:inputParameter name="variable_name">response_cadastro_pj</camunda:inputParameter>
          <camunda:inputParameter name="handel_error">true</camunda:inputParameter>
          <camunda:inputParameter name="base_path_env">nexaiq_base_url</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_010vv72</bpmn:incoming>
      <bpmn:outgoing>Flow_1vmvd8k</bpmn:outgoing>
    </bpmn:serviceTask>
