<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0w9uo2i" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.29.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.22.0">
  <bpmn:process id="cedc0c39-507e-4d9e-a108-6b79714ee6a6" name="WIP_nexaiq_cadastro_pj" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_1mgmwnc</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:scriptTask id="Proccess_NEXAIQ_Cadastro_PJ" name="Proccess NEXAIQ Cadastro PJ" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1vmvd8k</bpmn:incoming>
      <bpmn:outgoing>Flow_08xyb7e</bpmn:outgoing>
      <bpmn:script>function formatDateBRtoISO(dateStr) {
  if (!dateStr || !dateStr.includes("/")) return "Information not available";
  const [day, month, year] = dateStr.split("/");
  return `${year}-${month.padStart(2, "0")}-${day.padStart(2, "0")}`;
}

const response_cadastro_pj = JSON.parse(execution.getVariable("response_cadastro_pj"));

const total_number_of_employees =
 response_cadastro_pj.response.informacoes_pj.quantidade_funcionarios ??
  "Information not available";

const company_data_nexaiq = {
  company_document_number_completed:
    response_cadastro_pj.response.dados_cadastrais_pj.cnpj_basico ??
    "Information not available",
  legal_name:
    response_cadastro_pj.response.dados_cadastrais_pj.razao_social ??
    "Information not available",
  share_capital:
    response_cadastro_pj.response.dados_cadastrais_pj.capital_social ??
    "Information not available",
  registration_status:
    response_cadastro_pj.response.dados_cadastrais_pj.situacao_cadastral ??
    "Information not available",
  registration_status_reason:
    response_cadastro_pj.response.dados_cadastrais_pj.motivo_situacao_cadastral ??
    "Information not available",
  email:
    response_cadastro_pj.response.dados_cadastrais_pj.email ??
    "Information not available",
  special_status:
    response_cadastro_pj.response.dados_cadastrais_pj.situacao_especial ??
    "Information not available",

  cnae: (() =&gt; {
    const cnae_raw = response_cadastro_pj.response.dados_cadastrais_pj.cnae_principal;
    if (!cnae_raw) return { code: "Information not available", description: "Information not available" };
    const [code, description] = cnae_raw.split(" - ");
    return {
      code: code.trim(),
      description: description.trim(),
    };
  })(),

  legal_nature: {
    description:
      response_cadastro_pj.response.dados_cadastrais_pj.natureza_juridica ??
      "Information not available",
  },

  company_start_date: formatDateBRtoISO(
    response_cadastro_pj.response.dados_cadastrais_pj.data_inicio_atividade
  ),

  company_size:
    response_cadastro_pj.response.informacoes_pj.porte_empresa ??
    response_cadastro_pj.response.dados_cadastrais_pj.porte_empresa ??
    "Information not available",
  turnover_rate:
    response_cadastro_pj.response.informacoes_pj.indice_turnover ??
    "Information not available",
  annual_revenue:
    response_cadastro_pj.response.informacoes_pj.faturamento ??
    "Information not available",
  default_risk:
    response_cadastro_pj.response.informacoes_pj.risco_default ??
    "Information not available",
};


execution.setVariable("company_data_nexaiq", JSON.stringify(company_data_nexaiq));
execution.setVariable("total_number_of_employees", total_number_of_employees);</bpmn:script>
    </bpmn:scriptTask>
