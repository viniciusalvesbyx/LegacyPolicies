    <bpmn:serviceTask id="Consult_Personal_Income_PH3A" name="Consult Personal Income PH3A" camunda:asyncAfter="true" camunda:type="external" camunda:topic="PH3ARequestPersonalIncome">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="timeout">30000</camunda:inputParameter>
          <camunda:inputParameter name="variable_name">response_personal_income_ph3A</camunda:inputParameter>
