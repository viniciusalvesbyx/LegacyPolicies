    <bpmn:scriptTask id="Proccess_Personal_Income_PH3A" name="Proccess Personal Income PH3A" scriptFormat="JavaScript">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_1gu790l</bpmn:incoming>
      <bpmn:outgoing>Flow_18edgfs</bpmn:outgoing>
      <bpmn:script>const response_personal_income_ph3A = JSON.parse(execution.getVariable("response_personal_income_ph3A"));

const personal_income_ph3A = response_personal_income_ph3A.Data.Income.Personal

execution.setVariable("personal_income_ph3A", personal_income_ph3A);
execution.setVariable("has_personal_income_ph3A", true);</bpmn:script>
    </bpmn:scriptTask>
