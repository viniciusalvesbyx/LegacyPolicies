<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0w9uo2i" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.29.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.22.0">
  <bpmn:process id="WIP_nexaiq_cadastro_pj" name="WIP_nexaiq_cadastro_pj" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_1mgmwnc</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:scriptTask id="Proccess_NEXAIQ_Cadastro_PJ" name="Proccess NEXAIQ Cadastro PJ" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1vmvd8k</bpmn:incoming>
      <bpmn:outgoing>Flow_08xyb7e</bpmn:outgoing>
      <bpmn:script>const response_cadastro_pj = JSON.parse(execution.getVariable("response_cadastro_pj"));

const total_number_of_employees = response_cadastro_pj.response.informacoes_pj.quantidade_funcionarios ? response_cadastro_pj.response.informacoes_pj.quantidade_funcionarios : "Information not available";
const company_document_number_completed= response_cadastro_pj.response.dados_cadastrais_pj.cnpj_basico ? response_cadastro_pj.response.dados_cadastrais_pj.cnpj_basico : "Information not available";
const legal_name= response_cadastro_pj.response.dados_cadastrais_pj.razao_social ? response_cadastro_pj.response.dados_cadastrais_pj.razao_social : "Information not available";
const share_capital= response_cadastro_pj.response.dados_cadastrais_pj.capital_social ? response_cadastro_pj.response.dados_cadastrais_pj.capital_social : "Information not available";
const registration_status= response_cadastro_pj.response.dados_cadastrais_pj.situacao_cadastral ? response_cadastro_pj.response.dados_cadastrais_pj.situacao_cadastral : "Information not available";
const registration_status_reason= response_cadastro_pj.response.dados_cadastrais_pj.motivo_situacao_cadastral ? response_cadastro_pj.response.dados_cadastrais_pj.motivo_situacao_cadastral : "Information not available";
const company_start_date= response_cadastro_pj.response.dados_cadastrais_pj.data_inicio_atividade ? response_cadastro_pj.response.dados_cadastrais_pj.data_inicio_atividade : "Information not available";
const email= response_cadastro_pj.response.dados_cadastrais_pj.email ? response_cadastro_pj.response.dados_cadastrais_pj.email : "Information not available";
const special_status= response_cadastro_pj.response.dados_cadastrais_pj.situacao_especial ? response_cadastro_pj.response.dados_cadastrais_pj.situacao_especial : "Information not available";

const cnae_raw = response_cadastro_pj.response.dados_cadastrais_pj.cnae_principal;

const [code, description] = cnae_raw ? cnae_raw.split(" - ") : ["Information not available", "Information not available"];

const cnae = {
  code: code.trim(),
  description: description.trim(),
};

const legal_nature = {
  description: response_cadastro_pj.response.dados_cadastrais_pj.natureza_juridica ? response_cadastro_pj.response.dados_cadastrais_pj.natureza_juridica : "Information not available",
};

const company_size = response_cadastro_pj.response.informacoes_pj.porte_empresa ? response_cadastro_pj.response.informacoes_pj.porte_empresa : response_cadastro_pj.response.dados_cadastrais_pj.porte_empresa;
const turnover_rate = response_cadastro_pj.response.informacoes_pj.indice_turnover ? response_cadastro_pj.response.informacoes_pj.indice_turnover : "Information not available";
const annual_revenue = response_cadastro_pj.response.informacoes_pj.faturamento ? response_cadastro_pj.response.informacoes_pj.faturamento : "Information not available";
const default_risk = response_cadastro_pj.response.informacoes_pj.risco_default ? response_cadastro_pj.response.informacoes_pj.risco_default : "Information not available";

execution.setVariable("total_number_of_employees", total_number_of_employees);
execution.setVariable("company_document_number_completed", company_document_number_completed);
execution.setVariable("legal_name", legal_name);
execution.setVariable("legal_nature", legal_nature);
execution.setVariable("share_capital", share_capital);  
execution.setVariable("registration_status", registration_status);
execution.setVariable("registration_status_reason", registration_status_reason);
execution.setVariable("company_start_date", company_start_date);
execution.setVariable("email", email);
execution.setVariable("special_status", special_status);
execution.setVariable("cnae", cnae);
execution.setVariable("company_size", company_size);
execution.setVariable("turnover_rate", turnover_rate);
execution.setVariable("annual_revenue", annual_revenue);
execution.setVariable("default_risk", default_risk);</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1mgmwnc" sourceRef="StartEvent_1" targetRef="Activity_1kx0520" />
    <bpmn:scriptTask id="Activity_1kx0520" name="Preparar variaveis" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1mgmwnc</bpmn:incoming>
      <bpmn:outgoing>Flow_0gph2j5</bpmn:outgoing>
      <bpmn:script>const input_data_raw = execution.getVariable("input_data");
const input_data = JSON.parse(input_data_raw);

execution.setVariable("is_eligible_for_loan", input_data.is_eligible_for_loan);
execution.setVariable("contract_end_date", !input_data.contract_end_date ? false : true);
execution.setVariable("leave_of_absense", input_data.leave_of_absense);
execution.setVariable("termination_notice", input_data.termination_notice);
execution.setVariable("is_pep", input_data.is_pep);
execution.setVariable("employment_duration_in_months", input_data.employment_duration_in_months);
execution.setVariable("company_document_number", input_data.company_document_number);
execution.setVariable("age", input_data.age);
execution.setVariable("gender", input_data.gender);
execution.setVariable("available_consignment_margin", input_data.available_consignment_margin);
execution.setVariable("remuneration", parseFloat(input_data.base_margin_amount));
// execution.setVariable("active_or_suspended_loan_count", input_data.active_or_suspended_loan_count);


if (input_data &amp;&amp; input_data.cbo &amp;&amp; input_data.cbo.code) {
  const code = input_data.cbo.code.toString();

  const groupCboCode = code.slice(0, 1);
  const familyCboCode = code.slice(0, 4);

  execution.setVariable("group_cbo_code", groupCboCode);
  execution.setVariable("family_cbo_code", familyCboCode);
}
if (input_data &amp;&amp; input_data.scr) {
  execution.setVariable("scr_total_overdue_amount", input_data.scr.total_overdue_amount);
  execution.setVariable("scr_written_off_amount", input_data.scr.written_off_amount);
  execution.setVariable("scr_loan_due_amount_within_360d", input_data.scr.loan_due_amount_within_360d);
  execution.setVariable("scr_total_consignment_loan_overdue_amount", input_data.scr.total_consignment_loan_overdue_amount);
  execution.setVariable("scr_consignment_loan_written_off_amount", input_data.scr.consignment_loan_written_off_amount);
  execution.setVariable("scr_consignment_loan_due_amount", input_data.scr.consignment_loan_due_amount);
  execution.setVariable("scr_total_clean_loan_overdue_amount", input_data.scr.total_clean_loan_overdue_amount);
  execution.setVariable("scr_clean_loan_written_off_amount", input_data.scr.clean_loan_written_off_amount);
  execution.setVariable("scr_clean_loan_due_amount", input_data.scr.clean_loan_due_amount);
}</bpmn:script>
    </bpmn:scriptTask>
