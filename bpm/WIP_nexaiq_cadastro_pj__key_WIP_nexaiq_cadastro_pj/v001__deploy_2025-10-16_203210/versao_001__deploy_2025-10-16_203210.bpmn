    <bpmn:serviceTask id="Consulta_NEXAIQ_Cadastro_PJ" name="Consulta NEXAIQ Cadastro PJ" camunda:asyncAfter="true" camunda:type="external" camunda:topic="RestPostApi">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="url">https://api.nexaiq.com.br/datacredit/consulta/cadastro/v1/pj</camunda:inputParameter>
          <camunda:inputParameter name="body">{
  "cnpj": "42603664000195"
}</camunda:inputParameter>
          <camunda:inputParameter name="authenticate">{
    "user": "It1uLV3u9Ld3EQS8T4ccpus6pSRXjpVe",
    "password": "9yD2CPHwX3Z6UbBBedf5YRO236OkyWaO",
    "grant_type": "client_credentials",
    "path": "https://api.nexaiq.com.br/datacredit/consulta/cadastro/v1/oauth2/token"
}</camunda:inputParameter>
          <camunda:inputParameter name="timeout">60000</camunda:inputParameter>
          <camunda:inputParameter name="process">Consulta_NEXAIQ_Cadastro_PJ</camunda:inputParameter>
          <camunda:inputParameter name="variable_name">response_cadastro_pj</camunda:inputParameter>
