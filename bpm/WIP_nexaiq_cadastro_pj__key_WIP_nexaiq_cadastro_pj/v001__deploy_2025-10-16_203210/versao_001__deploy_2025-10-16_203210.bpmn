    <bpmn:serviceTask id="Consulta_Rest_SCR" name="Consulta SCR" camunda:asyncAfter="true" camunda:type="external" camunda:topic="RestPostApi">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="url">/banking/originator/scr</camunda:inputParameter>
          <camunda:inputParameter name="body"> ${body_request_scr}</camunda:inputParameter>
          <camunda:inputParameter name="authenticate">{
    "user": "celcoin_originator_client_id",
    "password": "celcoin_originator_secret_id",
    "grant_type": "client_credentials",
    "path": "celcoin_auth_url"
}</camunda:inputParameter>
          <camunda:inputParameter name="timeout">60000</camunda:inputParameter>
          <camunda:inputParameter name="variable_name">response_scr</camunda:inputParameter>
          <camunda:inputParameter name="base_path_env">celcoin_base_url</camunda:inputParameter>
          <camunda:inputParameter name="handler_error">true</camunda:inputParameter>
          <camunda:inputParameter name="log_reponse">true</camunda:inputParameter>
        </camunda:inputOutput>
