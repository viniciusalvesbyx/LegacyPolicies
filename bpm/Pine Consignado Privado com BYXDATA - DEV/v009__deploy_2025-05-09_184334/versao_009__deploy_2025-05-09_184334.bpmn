    <bpmn:scriptTask id="Activity_0sndu5s" name="Processar variáveis para DMN3" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_100qgod</bpmn:incoming>
      <bpmn:outgoing>Flow_0z00zam</bpmn:outgoing>
      <bpmn:script>// DÍVIDA FGTS
var response_divida_fgts_raw = execution.getVariable("response_divida_fgts");
const response_divida_fgts = JSON.parse(response_divida_fgts_raw);

const fgtsList = response_divida_fgts?.fgts || [];
var hasFgtsDebt = Array.isArray(fgtsList) &amp;&amp; fgtsList.length &gt; 0;

execution.setVariable("fgts_payment_delay_record", hasFgtsDebt);

// DÍVIDA ATIVA
var response_divida_ativa_raw = execution.getVariable("response_divida_ativa");
const response_divida_ativa = JSON.parse(response_divida_ativa_raw);

const dividaAtivaList = response_divida_ativa?.dividaAtiva || [];
var hasPublicDebt = Array.isArray(dividaAtivaList) &amp;&amp; dividaAtivaList.length &gt; 0;

execution.setVariable("public_tax_debt", hasPublicDebt);

// DÍVIDA PREVIDENCIÁRIA
const response_divida_previdenciaria_raw = execution.getVariable("response_divida_previdenciaria");
const response_divida_previdenciaria = JSON.parse(response_divida_previdenciaria_raw);

const previdenciariaList = response_divida_previdenciaria?.dividaPrevidenciaria || [];
var hasSocialSecurityDebt = Array.isArray(previdenciariaList) &amp;&amp; previdenciariaList.length &gt; 0;

execution.setVariable("social_security_active_debt", hasSocialSecurityDebt);



</bpmn:script>
    </bpmn:scriptTask>
