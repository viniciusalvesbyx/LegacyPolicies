    <bpmn:scriptTask id="Activity_0zu84yy" name="Preparar variáveis para DMN1.1 ou 1.2" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1hb159b</bpmn:incoming>
      <bpmn:outgoing>Flow_1uqngz8</bpmn:outgoing>
      <bpmn:script>const input_data_raw = execution.getVariable("input_data");
const input_data = JSON.parse(input_data_raw);

execution.setVariable("is_eligible_for_loan", input_data.is_eligible_for_loan);
execution.setVariable("contract_end_date", !input_data.contract_end_date ? false : true);
execution.setVariable("leave_of_absense", input_data.leave_of_absense);
execution.setVariable("termination_notice", input_data.termination_notice);
execution.setVariable("is_pep", input_data.is_pep);
execution.setVariable("employment_duration_in_months", input_data.employment_duration_in_months);
execution.setVariable("company_document_number", input_data.company_document_number);
execution.setVariable("age", input_data.age);
execution.setVariable("gender", input_data.gender);


if (input_data &amp;&amp; input_data.cbo &amp;&amp; input_data.cbo.code) {
  const code = input_data.cbo.code.toString();

  const groupCboCode = code.slice(0, 1);
  const familyCboCode = code.slice(0, 4);

  execution.setVariable("group_cbo_code", groupCboCode);
  execution.setVariable("family_cbo_code", familyCboCode);
}</bpmn:script>
    </bpmn:scriptTask>
