    <bpmn:scriptTask id="Activity_19st0i2" name="Calculate MaxTotalNumberOfInstallments" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0i6f6eu</bpmn:incoming>
      <bpmn:outgoing>Flow_0v6ergl</bpmn:outgoing>
      <bpmn:script>const input_data_raw = execution.getVariable("input_data");
const input_data = JSON.parse(input_data_raw);
const result_natural_person = execution.getVariable("result_natural_person");

const age = input_data.age;
const gender = input_data.gender;
const min_total_number_of_installments = result_natural_person.min_total_number_of_installments;
let max_total_number_of_installments = result_natural_person.max_total_number_of_installments;

var final_age = age + max_total_number_of_installments/12

if (gender == "female" &amp;&amp; final_age &gt; 59){
  max_total_number_of_installments = (59 - age)*12
}
else if (gender == "male" &amp;&amp; final_age &gt; 64){
  max_total_number_of_installments = (64 - age)*12
}

execution.setVariable("max_total_number_of_installments", max_total_number_of_installments );
execution.setVariable("min_total_number_of_installments", min_total_number_of_installments );</bpmn:script>
    </bpmn:scriptTask>
