    <bpmn:scriptTask id="Activity_07xb35r" name="Preparar CreditTermsConditions" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0v6ergl</bpmn:incoming>
      <bpmn:outgoing>Flow_1xqtz3y</bpmn:outgoing>
      <bpmn:script>const result_natural_person = execution.getVariable("result_natural_person");
const min_total_number_of_installments = execution.getVariable("min_total_number_of_installments");
const max_total_number_of_installments = execution.getVariable("max_total_number_of_installments");
const installment_amount = execution.getVariable("installment_amount");

const min_disbursement_amount = result_natural_person.min_disbursement_amount;
const max_disbursement_amount = result_natural_person.max_disbursement_amount;
const interest_rate = result_natural_person.interest_rate;

const credit_terms_conditions = [{
    "min_total_number_of_installments": min_total_number_of_installments,
    "max_total_number_of_installments": max_total_number_of_installments,
    "min_installment_amount": installment_amount ? installment_amount : 0,
    "max_installment_amount": installment_amount ? installment_amount : 0,
    "min_disbursement_amount": min_disbursement_amount,
    "max_disbursement_amount": max_disbursement_amount, 
    "interest": {
      "interest_rate_type": "pre_fixed",
      "pre_fixed": {
        "min_monthly_rate": interest_rate,
        "max_monthly_rate": interest_rate,
        "interest_base": 360 
      }
    },
    "taxes": {
      "has_iof": true,
    },
    "fees": [] 
  }]

const jsonString = JSON.stringify(credit_terms_conditions); 
execution.setVariable("credit_terms_conditions", jsonString);</bpmn:script>
