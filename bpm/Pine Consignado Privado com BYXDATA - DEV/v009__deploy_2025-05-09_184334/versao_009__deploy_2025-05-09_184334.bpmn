    <bpmn:scriptTask id="Processar_variaveis_LocalizadorPjResult" name="Processar variáveis LocalizadorPjResult" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_11s1eg8</bpmn:incoming>
      <bpmn:outgoing>Flow_1lspe41</bpmn:outgoing>
      <bpmn:script>var content = execution.getVariable("localizador_pj_result");

if (!content) {
  throw new Error("Variável localizador_pj_result não encontrada");
}

const company_content = JSON.parse(content);

var company_age_in_years = company_content.company_age_in_years;
var cnae_code = company_content.cnae?.code;
var legal_nature = company_content.legal_nature?.code;

execution.setVariable("company_age_in_years", company_age_in_years || null);
execution.setVariable("cnae_code", cnae_code || null);
execution.setVariable("legal_nature_code", legal_nature || null);

// LocalizadorPjSituacaoCadastral
var localizador_pj_situacao_cadastral_result = execution.getVariable("localizador_pj_situacao_cadastral_result");

if (!localizador_pj_situacao_cadastral_result) {
  throw new Error("Variável localizador_pj_situacao_cadastral_result não encontrada");
}

const localizador_pj_situacao_cadastral_result_parsed = JSON.parse(localizador_pj_situacao_cadastral_result);

var company_document_number_status = localizador_pj_situacao_cadastral_result_parsed.company_document_number_status

execution.setVariable("company_document_number_status", company_document_number_status || null);

// LocalizadorPjSocioDemografico
var localizador_pj_perfil_sociodemografico_result = execution.getVariable("localizador_pj_perfil_sociodemografico_result");

if (!localizador_pj_perfil_sociodemografico_result) {
  throw new Error("Variável localizador_pj_perfil_sociodemografico_result não encontrada");
}

const localizador_pj_perfil_sociodemografico_result_parsed = JSON.parse(localizador_pj_perfil_sociodemografico_result);

var number_of_employees = localizador_pj_perfil_sociodemografico_result_parsed.number_of_employees

execution.setVariable("number_of_employees", number_of_employees || null);

</bpmn:script>
    </bpmn:scriptTask>
