    <bpmn:businessRuleTask id="Activity_1m0lgt5" name="Avaliação CNPJ DMN3" camunda:resultVariable="result_legal_person" camunda:decisionRef="Pine_DMN_3" camunda:mapDecisionResult="singleResult">
