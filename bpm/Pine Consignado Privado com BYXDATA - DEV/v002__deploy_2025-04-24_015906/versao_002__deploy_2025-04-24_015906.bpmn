    <bpmn:scriptTask id="Activity_0zu84yy" name="Preparar variáveis para DMN1.1 ou 1.2" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1hb159b</bpmn:incoming>
      <bpmn:outgoing>Flow_1uqngz8</bpmn:outgoing>
      <bpmn:script>const input_data_raw = execution.getVariable("input_data");
const input_data = JSON.parse(input_data_raw);

execution.setVariable("is_eligible_for_loan", input_data.is_eligible_for_loan);
execution.setVariable("contract_end_date", !input_data.contract_end_date ? false : true);
execution.setVariable("leave_of_absense", input_data.leave_of_absense);
execution.setVariable("termination_notice", input_data.termination_notice);
execution.setVariable("is_pep", input_data.is_pep);
execution.setVariable("employment_duration_in_months", input_data.employment_duration_in_months);
execution.setVariable("company_document_number", input_data.company_document_number);
execution.setVariable("age", input_data.age);
execution.setVariable("gender", input_data.gender);


if (input_data &amp;&amp; input_data.cbo &amp;&amp; input_data.cbo.code) {
  const code = input_data.cbo.code.toString();

  const groupCboCode = code.slice(0, 1);
  const familyCboCode = code.slice(0, 4);

  execution.setVariable("group_cbo_code", groupCboCode);
  execution.setVariable("family_cbo_code", familyCboCode);
}</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1chduov" sourceRef="Avaliacao_CPF_DMN1" targetRef="Gateway_0105f2o" />
    <bpmn:sequenceFlow id="Flow_1uqngz8" sourceRef="Activity_0zu84yy" targetRef="Activity_1rabns2" />
    <bpmn:startEvent id="Event_15pza2w">
      <bpmn:outgoing>Flow_1hb159b</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1hb159b" sourceRef="Event_15pza2w" targetRef="Activity_0zu84yy" />
    <bpmn:scriptTask id="Preparar_Retorno" name="Preparar Retorno Geral" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1tax62w</bpmn:incoming>
      <bpmn:outgoing>Flow_0wkn7ry</bpmn:outgoing>
      <bpmn:script>const document_number = execution.getVariable("document_number");
const credit_terms_key = execution.getVariable("credit_terms_key");
const input_data_raw = execution.getVariable("input_data");
const cnpj_blocked = execution.getVariable("cnpj_blocked");

const input_data = JSON.parse(input_data_raw);

const result_natural_person = execution.getVariable("result_natural_person");
const natural_person_status = result_natural_person.status;
const natural_person_reason = result_natural_person.reason;
const age = input_data.age;
const gender = input_data.gender;
const min_total_number_of_installments = result_natural_person.min_total_number_of_installments;
let max_total_number_of_installments = result_natural_person.max_total_number_of_installments;
const min_disbursement_amount = result_natural_person.min_disbursement_amount;
const max_disbursement_amount = result_natural_person.max_disbursement_amount;
const interest_rate = result_natural_person.interest_rate;

var final_age
var legal_person_status = "approved"
var legal_person_reason

var identification = { }

var decision = {
  "natural_person_reason": natural_person_reason,
}

if (cnpj_blocked != null) {
  decision["cnpj_blocked"] = cnpj_blocked
}
if (cnpj_blocked) {
  legal_person_reason = "CNPJ Blocklist restriction"
  decision["legal_person_reason"] = legal_person_reason
  legal_person_status = "denied"
}

let credit_terms_conditions = null

var getStatus = () =&gt; {
  if(natural_person_status == "denied" || legal_person_status == "denied"){
      return "denied";
  }else if(natural_person_status === "approved" &amp;&amp; legal_person_status === "approved"){
      return "approved";
  }else{
      return "ERROR";
  }
} 

var final_status = getStatus()

if (final_status == "approved"){
  final_age = age + max_total_number_of_installments/12

  if (gender == "female" &amp;&amp; final_age &gt; 59){
    max_total_number_of_installments = (59 - age)*12
  }
  else if (gender == "male" &amp;&amp; final_age &gt; 64){
    max_total_number_of_installments = (64 - age)*12
  }
  credit_terms_conditions = [{
    "min_total_number_of_installments": min_total_number_of_installments,
    "max_total_number_of_installments": max_total_number_of_installments,
    "min_installment_amount": null,
    "max_installment_amount": null,
    "min_disbursement_amount": min_disbursement_amount,
    "max_disbursement_amount": max_disbursement_amount, 
    "interest": {
      "interest_rate_type": "pre_fixed",
      "pre_fixed": {
        "min_monthly_rate": interest_rate,
        "max_monthly_rate": interest_rate,
        "interest_base": 360 
      }
    },
    "taxes": {
      "has_iof": true,
    },
    "fees": [] 
  }]
}

var getCancelReason = () =&gt; {
  if(natural_person_reason &amp;&amp; legal_person_reason){
      return natural_person_reason + " - " + legal_person_reason;
  }else if(natural_person_reason &amp;&amp; !legal_person_reason){
      return natural_person_reason;
  }else if(!natural_person_reason &amp;&amp; legal_person_reason){
      return legal_person_reason;
  }else{
      return "ERROR";
  }
} 

var jsonData = {
  "document_number": document_number, 
//  "credit_terms_key": credit_terms_key, // REMOVER DEPOIS, SÓ TER CERTEZA Q ESTÁ SENDO CAPTURADO
  "status": final_status, 
  "credit_terms_conditions": credit_terms_conditions,
  "decision_metadata": {
      "identification": identification,
      "decision": decision,
  }, 
  "input_data": input_data,
};

if (final_status == "denied"){
  jsonData["cancel_reason"] = getCancelReason();
  jsonData['credit_terms_conditions'] = null;
}

var jsonString = JSON.stringify(jsonData); 
execution.setVariable("body_result3", jsonString);
</bpmn:script>
    </bpmn:scriptTask>
