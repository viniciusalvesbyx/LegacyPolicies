    <bpmn:scriptTask id="Activity_1rre24q" name="Preparar Retorno FINAL" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1hcq0i6</bpmn:incoming>
      <bpmn:outgoing>Flow_1sv9zvi</bpmn:outgoing>
      <bpmn:script>// 1. ENRIQUECER IDENTIFICATION
var content = execution.getVariable("localizador_pj_result"); // 1. enriquecer identification
var localizador_pj_situacao_cadastral_result = execution.getVariable("localizador_pj_situacao_cadastral_result"); // 1. enriquecer identification
var localizador_pj_perfil_sociodemografico_result = execution.getVariable("localizador_pj_perfil_sociodemografico_result"); // 1. enriquecer identification
var social_security_sick_leave_recurrence = execution.getVariable("social_security_sick_leave_recurrence"); // 1. enriquecer identification
var fgts_payment_delay_record = execution.getVariable("fgts_payment_delay_record"); // 1. enriquecer identification
var public_tax_debt = execution.getVariable("public_tax_debt"); // 1. enriquecer identification
var social_security_active_debt = execution.getVariable("social_security_active_debt"); // 1. enriquecer identification

var afastamento_raw = execution.getVariable("response_afastamento"); // 1. enriquecer identification
const afastamento = JSON.parse(afastamento_raw); // 1. enriquecer identification

var response_divida_fgts_raw = execution.getVariable("response_divida_fgts"); // 1. enriquecer identification
const response_divida_fgts = JSON.parse(response_divida_fgts_raw); // 1. enriquecer identification

var response_divida_ativa_raw = execution.getVariable("response_divida_ativa"); // 1. enriquecer identification
const response_divida_ativa = JSON.parse(response_divida_ativa_raw); // 1. enriquecer identification

var response_divida_previdenciaria_raw = execution.getVariable("response_divida_previdenciaria"); // 1. enriquecer identification
const response_divida_previdenciaria = JSON.parse(response_divida_previdenciaria_raw); // 1. enriquecer identification

const company_content = JSON.parse(content); // 1. enriquecer identification
const localizador_pj_situacao_cadastral_result_parsed = JSON.parse(localizador_pj_situacao_cadastral_result); // 1. enriquecer identification
const localizador_pj_perfil_sociodemografico_result_parsed = JSON.parse(localizador_pj_perfil_sociodemografico_result); // 1. enriquecer identification
 

// 2. body
const document_number = execution.getVariable("document_number");
const credit_terms_key = execution.getVariable("credit_terms_key");

// 3. input_data
const input_data_raw = execution.getVariable("input_data");
const input_data = JSON.parse(input_data_raw);

// 4. decision_metadata
const cnpj_blocked = execution.getVariable("cnpj_blocked");
const result_natural_person = execution.getVariable("result_natural_person");

let result_legal_person_raw = execution.getVariable("result_legal_person");
let result_legal_person;

if (typeof result_legal_person_raw === "string") {
  try {
    result_legal_person = JSON.parse(result_legal_person_raw);
  } catch (e) {
    throw new Error("Falha ao fazer parse de result_legal_person: " + e.message);
  }
} else {
  result_legal_person = result_legal_person_raw;
}

const natural_person_status = result_natural_person.status;
const natural_person_reason = result_natural_person.reason;
const legal_person_status = result_legal_person?.status;
const legal_person_reason = result_legal_person?.reason;

// 5. para cálculo de qtdade de parcela x idade
const age = input_data.age;
const gender = input_data.gender;

// 6. credit_terms conditions
const min_total_number_of_installments = result_natural_person.min_total_number_of_installments;
let max_total_number_of_installments = result_natural_person.max_total_number_of_installments;
const min_disbursement_amount = result_natural_person.min_disbursement_amount;
const max_disbursement_amount = result_natural_person.max_disbursement_amount;
const interest_rate = result_natural_person.interest_rate;

var final_age

// 1. identification
var identification = {
  "social_security_sick_leave_raw_data": afastamento, 
  "response_divida_fgts": response_divida_fgts,
  "response_divida_ativa": response_divida_ativa,
  "response_divida_previdenciaria": response_divida_previdenciaria,
  "social_security_sick_leave_recurrence": social_security_sick_leave_recurrence,
  "fgts_payment_delay_record": fgts_payment_delay_record,
  "public_tax_debt": public_tax_debt,
  "social_security_active_debt": social_security_active_debt
}

Object.assign(identification, company_content);
Object.assign(identification, localizador_pj_situacao_cadastral_result_parsed);
Object.assign(identification, localizador_pj_perfil_sociodemografico_result_parsed);

var decision = {
  "natural_person_reason": natural_person_reason,
  "natural_person_status": natural_person_status,
  "legal_person_reason": legal_person_reason,
  "legal_person_status": legal_person_status,
}

if (cnpj_blocked != null) {
  decision["cnpj_blocked"] = cnpj_blocked
}

var getStatus = () =&gt; {
  if(natural_person_status == "denied" || legal_person_status == "denied"){
      return "denied";
  }else if(natural_person_status == "approved" &amp;&amp; legal_person_status == "approved"){
      return "approved";
  }else{
      return "ERROR";
  }
} 

var final_status = getStatus()

let credit_terms_conditions

// CALCULO DE PRAZO X IDADE
if (final_status == "approved"){
  final_age = age + max_total_number_of_installments/12

  if (gender == "female" &amp;&amp; final_age &gt; 59){
    max_total_number_of_installments = (59 - age)*12
  }
  else if (gender == "male" &amp;&amp; final_age &gt; 64){
    max_total_number_of_installments = (64 - age)*12
  }
  credit_terms_conditions = [{
    "min_total_number_of_installments": min_total_number_of_installments,
    "max_total_number_of_installments": max_total_number_of_installments,
    "min_installment_amount": null,
    "max_installment_amount": null,
    "min_disbursement_amount": min_disbursement_amount,
    "max_disbursement_amount": max_disbursement_amount, 
    "interest": {
      "interest_rate_type": "pre_fixed",
      "pre_fixed": {
        "min_monthly_rate": interest_rate,
        "max_monthly_rate": interest_rate,
        "interest_base": 360 
      }
    },
    "taxes": {
      "has_iof": true,
    },
    "fees": [] 
  }]
}

var getCancelReason = () =&gt; {
  if(natural_person_reason &amp;&amp; legal_person_reason){
      return natural_person_reason + " - " + legal_person_reason;
  }else if(natural_person_reason &amp;&amp; !legal_person_reason){
      return natural_person_reason;
  }else if(!natural_person_reason &amp;&amp; legal_person_reason){
      return legal_person_reason;
  }else{
      return "ERROR";
  }
} 

var jsonData = {
  "document_number": document_number, 
  "status": final_status, 
  "credit_terms_conditions": credit_terms_conditions,
  "decision_metadata": {
      "identification": identification,
      "decision": decision,
  }, 
  "input_data": input_data,
};

if (final_status == "denied"){
  jsonData["cancel_reason"] = getCancelReason();
  jsonData['credit_terms_conditions'] = null;
}

var jsonString = JSON.stringify(jsonData); 
execution.setVariable("body_result3", jsonString);
</bpmn:script>
    </bpmn:scriptTask>
