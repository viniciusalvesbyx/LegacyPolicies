    <bpmn:businessRuleTask id="Activity_1nyvobw" name="Avaliação CNPJ DMN2" camunda:resultVariable="result_legal_person" camunda:decisionRef="Pine_DMN_2" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_1lspe41</bpmn:incoming>
