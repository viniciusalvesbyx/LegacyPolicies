    <bpmn:serviceTask id="Consultar_DXON_LocalizadorPjSituacaoCadastral" name="Consultar BYXDATA LocalizadorPjSituacaoCadastral" camunda:asyncAfter="true" camunda:type="external" camunda:topic="SoapPostApi">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="url">http://diretrixon.com/diretrixws/recupera.asmx</camunda:inputParameter>
          <camunda:inputParameter name="soap_action">http://diretrixon.com/WebServices/LocalizadorPjSituacaoCadastral</camunda:inputParameter>
          <camunda:inputParameter name="variable_name">localizador_pj_situacao_cadastral_result</camunda:inputParameter>
          <camunda:inputParameter name="body">
            <camunda:script scriptFormat="JavaScript">var cnpjRaw = execution.getVariable("company_document_number") || "";

function formatCNPJ(cnpj) {
  return cnpj.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, "$1.$2.$3/$4-$5");
}

var formattedCNPJ = formatCNPJ(cnpjRaw);

var soapBody =
'&lt;?xml version="1.0" encoding="utf-8"?&gt;' +
  '&lt;soap:Envelope xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" ' +
  'xmlns:xsd="http://www.w3.org/2001/XMLSchema" ' +
  'xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"&gt;' +
  '&lt;soap:Header&gt;' +
    '&lt;Login xmlns="http://diretrixon.com/WebServices"&gt;' +
      '&lt;Usuario&gt;APIconsigPrivado&lt;/Usuario&gt;' +
      '&lt;Senha&gt;xT3Zt3D@0nbYXx&lt;/Senha&gt;' +
      '&lt;Cliente&gt;ByxCapital&lt;/Cliente&gt;' +
    '&lt;/Login&gt;' +
  '&lt;/soap:Header&gt;' +
  '&lt;soap:Body&gt;' +
    '&lt;LocalizadorPjSituacaoCadastral xmlns="http://diretrixon.com/WebServices"&gt;' +
      '&lt;cnpj&gt;' + formattedCNPJ + '&lt;/cnpj&gt;' +
      '&lt;idProduto&gt;7&lt;/idProduto&gt;' +
    '&lt;/LocalizadorPjSituacaoCadastral&gt;' +
  '&lt;/soap:Body&gt;' +
'&lt;/soap:Envelope&gt;';

soapBody;</camunda:script>
          </camunda:inputParameter>
          <camunda:inputParameter name="mock_mode">${false}</camunda:inputParameter>
          <camunda:inputParameter name="response_json_path">soap:Envelope.soap:Body.LocalizadorPjSituacaoCadastralResponse.LocalizadorPjSituacaoCadastralResult</camunda:inputParameter>
          <camunda:inputParameter name="method">LocalizadorPjSituacaoCadastral</camunda:inputParameter>
          <camunda:inputParameter name="timeout">30000</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_090l1dn</bpmn:incoming>
      <bpmn:outgoing>Flow_0zvgx4q</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0105f2o">
      <bpmn:incoming>Flow_1chduov</bpmn:incoming>
      <bpmn:outgoing>Flow_0i6f6eu</bpmn:outgoing>
      <bpmn:outgoing>Flow_1ni7ly0</bpmn:outgoing>
    </bpmn:exclusiveGateway>
