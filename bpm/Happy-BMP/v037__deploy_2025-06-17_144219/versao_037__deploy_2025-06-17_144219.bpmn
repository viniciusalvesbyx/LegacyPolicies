    <bpmn:scriptTask id="Activity_1atokmd" name="Calcula Parcelas" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="max_disbursement_percent">${result_tax_values.max_disbursement_percent}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_16z8v8d</bpmn:incoming>
      <bpmn:outgoing>Flow_0x6m708</bpmn:outgoing>
      <bpmn:script>const result_tax_values= execution.getVariable("result_tax_values");
const available_consignment_margin = execution.getVariable("available_consignment_margin");
let installment_amount = available_consignment_margin * result_tax_values.max_amount_percent;
execution.setVariable("installment_amount", installment_amount);</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_07xb35r" name="Preparar CreditTermsConditions" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0x6m708</bpmn:incoming>
      <bpmn:outgoing>Flow_1flkf8j</bpmn:outgoing>
      <bpmn:script>const result_tax_values= execution.getVariable("result_tax_values");

const min_total_number_of_installments = result_tax_values.min_total_number_of_installments;
const max_total_number_of_installments = result_tax_values.max_total_number_of_installments;
const installment_amount = execution.getVariable("installment_amount");

const min_disbursement_amount = result_tax_values.min_disbursement_amount;
const max_disbursement_amount = result_tax_values.max_disbursement_amount;
const interest_rate = result_tax_values.interest_rate;

const credit_terms_conditions = [{
    "min_total_number_of_installments": min_total_number_of_installments,
    "max_total_number_of_installments": max_total_number_of_installments,
    "min_installment_amount": 0,
    "max_installment_amount": installment_amount ? installment_amount : 0,
    "min_disbursement_amount": min_disbursement_amount,
    "max_disbursement_amount": max_disbursement_amount, 
    "interest": {
      "interest_rate_type": "pre_fixed",
      "pre_fixed": {
        "min_monthly_rate": interest_rate,
        "max_monthly_rate": interest_rate,
        "interest_base": 360 
      }
    },
    "taxes": {
      "has_iof": true,
    },
    "fees": [] 
  }]

const jsonString = JSON.stringify(credit_terms_conditions); 
execution.setVariable("credit_terms_conditions", jsonString);</bpmn:script>
    </bpmn:scriptTask>
