    <bpmn:businessRuleTask id="Activity_1tzmydy" name="Define Tipo Empresa" camunda:resultVariable="result_type_company" camunda:decisionRef="Decision_Type_Company" camunda:mapDecisionResult="singleResult">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="share_capital">${company_data.share_capital}</camunda:inputParameter>
          <camunda:outputParameter name="type_company">${result_type_company.type_company}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
