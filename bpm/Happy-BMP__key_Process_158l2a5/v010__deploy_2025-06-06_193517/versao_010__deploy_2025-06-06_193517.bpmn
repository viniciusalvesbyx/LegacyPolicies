    <bpmn:scriptTask id="Activity_0fg11nx" name="Preparar identification" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0nwb58x</bpmn:incoming>
      <bpmn:outgoing>Flow_0z7mndg</bpmn:outgoing>
      <bpmn:script>const afastamento_raw = execution.getVariable("response_afastamento");
const afastamento = JSON.parse(afastamento_raw);

const response_divida_fgts_raw = execution.getVariable("response_divida_fgts");
const response_divida_fgts = JSON.parse(response_divida_fgts_raw);

const response_divida_ativa_raw = execution.getVariable("response_divida_ativa");
const response_divida_ativa = JSON.parse(response_divida_ativa_raw);

const response_divida_previdenciaria_raw = execution.getVariable("response_divida_previdenciaria");
const response_divida_previdenciaria = JSON.parse(response_divida_previdenciaria_raw);

const content = execution.getVariable("localizador_pj_result");
const company_content = JSON.parse(content);

const localizador_pj_situacao_cadastral_result = execution.getVariable("localizador_pj_situacao_cadastral_result");
const localizador_pj_situacao_cadastral_result_parsed = JSON.parse(localizador_pj_situacao_cadastral_result);

const localizador_pj_perfil_sociodemografico_result = execution.getVariable("localizador_pj_perfil_sociodemografico_result"); 
const localizador_pj_perfil_sociodemografico_result_parsed = JSON.parse(localizador_pj_perfil_sociodemografico_result); 

const social_security_sick_leave_recurrence = execution.getVariable("social_security_sick_leave_recurrence");
const fgts_payment_delay_record = execution.getVariable("fgts_payment_delay_record");
const public_tax_debt = execution.getVariable("public_tax_debt");
const social_security_active_debt = execution.getVariable("social_security_active_debt");

const group_cbo_code = execution.getVariable("group_cbo_code");
const family_cbo_code = execution.getVariable("family_cbo_code");

var identification = {
  "social_security_sick_leave_raw_data": afastamento, 
  "response_divida_fgts": response_divida_fgts?.fgts?.length,
  "response_divida_ativa": response_divida_ativa?.dividaAtiva?.length,
  "response_divida_previdenciaria": response_divida_previdenciaria?.dividaPrevidenciaria?.length,
  "social_security_sick_leave_recurrence": social_security_sick_leave_recurrence,
  "fgts_payment_delay_record": fgts_payment_delay_record,
  "public_tax_debt": public_tax_debt,
  "social_security_active_debt": social_security_active_debt,
  "group_cbo_code": group_cbo_code,
  "family_cbo_code": family_cbo_code
}

Object.assign(identification, company_content);
Object.assign(identification, localizador_pj_situacao_cadastral_result_parsed);
Object.assign(identification, localizador_pj_perfil_sociodemografico_result_parsed);

var jsonString = JSON.stringify(identification); 
execution.setVariable("decision_metadata_identification", jsonString);</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_04akl5a" name="Preparar decision" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0z7mndg</bpmn:incoming>
      <bpmn:outgoing>Flow_1eanti6</bpmn:outgoing>
      <bpmn:script>var identification_raw = execution.getVariable("decision_metadata_identification");
const identification = JSON.parse(identification_raw);

const result_natural_person = execution.getVariable("result_natural_person");
let result_legal_person_raw = execution.getVariable("result_legal_person");
let result_legal_person;

if (typeof result_legal_person_raw === "string") {
  try {
    result_legal_person = JSON.parse(result_legal_person_raw);
  } catch (e) {
    throw new Error("Falha ao fazer parse de result_legal_person: " + e.message);
  }
} else {
  result_legal_person = result_legal_person_raw;
}

const natural_person_status = result_natural_person.status;
const natural_person_reason = result_natural_person.reason;
const legal_person_status = result_legal_person?.status;
const legal_person_reason = result_legal_person?.reason;
const installment_amount = execution.getVariable("installment_amount");

const cnpj_blocked = execution.getVariable("cnpj_blocked");

var decision = {
  "identification": identification,
  "decision": {
    "cnpj_blocked": cnpj_blocked,
    "natural_person_reason": natural_person_reason,
    "natural_person_status": natural_person_status,
    "legal_person_reason": legal_person_reason,
    "legal_person_status": legal_person_status,
    "installment_amount": installment_amount 
  }
};

var jsonString = JSON.stringify(decision); 
execution.setVariable("decision_metadata", jsonString);</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_0ew5iwy" name="Preparar retorno" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1eanti6</bpmn:incoming>
      <bpmn:outgoing>Flow_0kah6pd</bpmn:outgoing>
      <bpmn:script>const result_natural_person = execution.getVariable("result_natural_person");
let result_legal_person_raw = execution.getVariable("result_legal_person");
let result_legal_person;

if (typeof result_legal_person_raw === "string") {
  try {
    result_legal_person = JSON.parse(result_legal_person_raw);
  } catch (e) {
    throw new Error("Falha ao fazer parse de result_legal_person: " + e.message);
  }
} else {
  result_legal_person = result_legal_person_raw;
}

const natural_person_status = result_natural_person.status;
const natural_person_reason = result_natural_person.reason;
const legal_person_status = result_legal_person?.status;
const legal_person_reason = result_legal_person?.reason;

var cancel_reason =  "ERROR";
var final_status = "ERROR";

if(natural_person_status == "approved" &amp;&amp; legal_person_status == "approved"){
  final_status =  "approved";
  cancel_reason = "";
}else if(natural_person_status == "denied" &amp;&amp; legal_person_status == "denied"){
  final_status =  "denied";
  cancel_reason = natural_person_reason + " - " + legal_person_reason;
}else if(natural_person_status == "denied"){
  final_status =  "denied";
  cancel_reason = natural_person_reason;
}else if(legal_person_status == "denied"){
  final_status =  "denied";
  cancel_reason = legal_person_reason;
}

const document_number = execution.getVariable("document_number");

const credit_terms_conditions_raw = execution.getVariable("credit_terms_conditions");
const credit_terms_conditions = JSON.parse(credit_terms_conditions_raw);

const decision_metadata_raw = execution.getVariable("decision_metadata");
const decision_metadata = JSON.parse(decision_metadata_raw);

const input_data_raw = execution.getVariable("input_data");
const input_data = JSON.parse(input_data_raw);

var jsonData = {
  "document_number": document_number, 
  "status": final_status, 
  "credit_terms_conditions": credit_terms_conditions,
  "decision_metadata": decision_metadata, 
  "input_data": input_data,
};

if (final_status == "denied") {
  jsonData["cancel_reason"] = cancel_reason;
  jsonData['credit_terms_conditions'] = null;
}

var jsonString = JSON.stringify(jsonData); 
execution.setVariable("body_result3", jsonString);</bpmn:script>
    </bpmn:scriptTask>
