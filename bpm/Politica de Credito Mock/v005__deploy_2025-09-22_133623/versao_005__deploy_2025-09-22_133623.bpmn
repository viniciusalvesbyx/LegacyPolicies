const share_capital = execution.getVariable("share_capital");
const termination_notice = execution.getVariable("termination_notice");
const total_overdue_and_written_amount = execution.getVariable("total_overdue_and_written_amount");
const unauthorization_reason_code = execution.getVariable("unauthorization_reason_code");
const unauthorization_reason_description = execution.getVariable("unauthorization_reason_description");

var identification = {
  "legal_person": {
    "company_age_in_months": company_age_in_months,
    "company_document_number": company_document_number,
    "employer_name": employer_name,
    "legal_nature": legal_nature,
    "share_capital": share_capital,
  },
  "natural_person": {
    "active_or_suspended_loan_count": active_or_suspended_loan_count,
    "admission_date": admission_date,
    "age": age,
    "available_consignment_margin": available_consignment_margin,
    "cbo_code": cbo_code,
    "company_document_numbers": company_document_numbers,
    "contract_end_date": contract_end_date,
    "employment_duration_in_months": employment_duration_in_months,
