    <bpmn:scriptTask id="Activity_1vifjx2" name="Preparar variaveis SCR" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_14l5mbp</bpmn:incoming>
      <bpmn:outgoing>Flow_1klyq2k</bpmn:outgoing>
      <bpmn:script>const monthly_net_salary = execution.getVariable("monthly_net_salary");
const operacoes_raw = execution.getVariable("response_scr");
const operacoes_parsed = JSON.parse(operacoes_raw);

const operacoes = operacoes_parsed?.dados?.listaDeResumoDasOperacoes ?? [];

var total_overdue_amount = 0.0;
var written_off_amount = 0.0;
var loan_due_amount_within_360d = 0.0;
var total_consignment_loan_overdue_amount = 0.0;
var consignment_loan_due_amount = 0.0;
var overdue_amount_up_to_14_days = 0.0;
var overdue_amount_over_14_days = 0.0;

// Códigos de vencimento válidos para "loan_due_amount_within_360d" e "consignment_loan_due_amount"
var codigosDentro360d = ["v110", "v120", "v130", "v140", "v150"];
var codigosConsignado = [
  "v110", "v120", "v130", "v140", "v150",
  "v160", "v165", "v170", "v175", "v180", "v190", "v199"
];

for (var i = 0; i &lt; operacoes.length; i++) {
  var operacao = operacoes[i];
  var modalidade = operacao.modalidade;
  var vencimentos = operacao.listaDeVencimentos;

  for (var j = 0; j &lt; vencimentos.length; j++) {
    var venc = vencimentos[j];
    var codigo = venc.codigoVencimento;
    var valor = parseFloat(venc.valorVencimento);

    // Considerar somente modalidade começa com "02"
    if (modalidade.substring(0, 2) === "02") {

        // total_overdue_amount: código começa com "v2"
        if (codigo.substring(0, 2) === "v2") {
            total_overdue_amount += valor;

            if(codigo === "v205") {
                overdue_amount_up_to_14_days += valor;
            } else {
                overdue_amount_over_14_days += valor;
            }
        }

        // written_off_amount: código começa com "v3"
        if (codigo.substring(0, 2) === "v3") {
            written_off_amount += valor;
        }

        // loan_due_amount_within_360d: código é v110, v120, v130, v140, v150
        if (codigosDentro360d.indexOf(codigo) !== -1) {
            loan_due_amount_within_360d += valor;
        }

        // total_consignment_loan_overdue_amount: modalidade === "0202" + código começa com "v2"
        if (modalidade === "0202" &amp;&amp; codigo.substring(0, 2) === "v2") {
            total_consignment_loan_overdue_amount += valor;
        }

        // consignment_loan_due_amount: modalidade === "0202" + código dentro da lista
        if (modalidade === "0202" &amp;&amp; codigosConsignado.indexOf(codigo) !== -1) {
            consignment_loan_due_amount += valor;
        }
    }
  }
}

execution.setVariable("total_overdue_amount", parseFloat(total_overdue_amount));
execution.setVariable("written_off_amount", parseFloat(written_off_amount));
execution.setVariable("loan_due_amount_within_360d", parseFloat(loan_due_amount_within_360d));
execution.setVariable("total_consignment_loan_overdue_amount", parseFloat(total_consignment_loan_overdue_amount));
execution.setVariable("consignment_loan_due_amount", parseFloat(consignment_loan_due_amount));
execution.setVariable(
  "percent_income_360d",
  Math.round(((loan_due_amount_within_360d / 12) / monthly_net_salary) * 100) / 100
);
execution.setVariable("total_overdue_and_written_amount", parseFloat(total_overdue_amount + written_off_amount));
execution.setVariable("overdue_amount_up_to_14_days", parseFloat(overdue_amount_up_to_14_days));
execution.setVariable("overdue_amount_over_14_days", parseFloat(overdue_amount_over_14_days));</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1klyq2k" sourceRef="Activity_1vifjx2" targetRef="Gateway_0glcjc8" />
    <bpmn:scriptTask id="Activity_0uw596w" name="Cria natural_person com dados da Dataprev" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0xgfppf</bpmn:incoming>
      <bpmn:outgoing>Flow_0n3vwqt</bpmn:outgoing>
      <bpmn:script>const settings = JSON.parse(execution.getVariable("settings"));
const response_saldo = JSON.parse(execution.getVariable("response_saldo"));

var JsonUtil = Java.type("org.camunda.bpm.engine.impl.util.JsonUtil");
var company_data = JSON.parse(JsonUtil.asString(execution.getVariable("company_data")));

const HOLIDAY_ABSENCE_CODE = settings["HOLIDAY_ABSENCE_CODE"];
const UNAUTHORIZATION_REASON_MAP = settings["UNAUTHORIZATION_REASON_MAP"];

function calcula_tempo_em_meses(start_date) {
    const year = parseInt(start_date.substring(0, 4), 10);
    const month = parseInt(start_date.substring(5, 7), 10) - 1;
    const day = parseInt(start_date.substring(8, 10), 10);
    const today = new Date();
    const date = new Date(year, month, day);
    let years = today.getFullYear() - date.getFullYear();
    let months = today.getMonth() - date.getMonth();
    let totalYears = years * 12;
    let totalMonths = totalYears + months;
    if (today.getDate() &lt; date.getDate()) {
        totalMonths -= 1;
    }
    return [years, totalMonths];
};


// company document number without leading zeros
let balances = response_saldo.balances;
const company_document_number = String(parseInt(company_data.document_number, 10));
let company = null;
for (let i = 0; i &lt; balances.length; i++) {
  let item = balances[i];
  if (String(parseInt(item.company_document_number, 10)) == company_document_number) {
    company = item;
    break;
  }
}

var leave_of_absense = false;
if(company.meta_data.alerts != undefined) {
  for (var i = 0; i &lt; company.meta_data.alerts.length; i++) {
    var item = company.meta_data.alerts[i];
    if (item.absence_reason_code != undefined &amp;&amp; item.absence_reason_code &gt; 0 &amp;&amp; item.absence_reason_code != HOLIDAY_ABSENCE_CODE) {
      leave_of_absense = true;
      break;
    }
  }
}

var employment_duration = calcula_tempo_em_meses(company.meta_data.admission_date);
var age = calcula_tempo_em_meses(company.meta_data.birth_date);

var job_code_str = String(company.meta_data.job_code.code);
var family_cbo_code = job_code_str.length &gt;= 4 ? job_code_str.substring(0, 4) : job_code_str;

const unauthorization_reason_code = company?.meta_data?.unauthorization_reason?.code;

let unauthorization_reason_description = null;
if (unauthorization_reason_code !== undefined &amp;&amp; unauthorization_reason_code !== null) {
  unauthorization_reason_description = UNAUTHORIZATION_REASON_MAP[unauthorization_reason_code] || "Unknown reason";
}

execution.setVariable("natural_person", org.camunda.spin.Spin.JSON({
  "active_or_suspended_loan_count": company.meta_data.amount_loans_assets_suspended,
  "admission_date": company.meta_data.admission_date,
  "age": age[0],
  "available_consignment_margin": company.products[0].available_balance,
  "cbo_code": company.meta_data.job_code.code,
  "cbo_description": company.meta_data.job_code.description,
  "contract_end_date": company.meta_data.termination_date != undefined,
  "employee_number": company.employee.code,
  "employment_duration_in_months": employment_duration[1],
  "family_cbo_code": family_cbo_code,
  "gender": company.meta_data.gender.code == 1 ? "male" : "female",
  "is_eligible_for_loan": company.products[0].authorization.details[0].authorized,
  "is_pep": company.meta_data.politically_exposed_person != undefined &amp;&amp; company.meta_data.politically_exposed_person.code != 0,
  "leave_of_absense": leave_of_absense,
  "monthly_net_salary": parseFloat(company.meta_data.base_margin_value),
  "start_date": company.meta_data.employer_activity_start_date,
  "termination_date": company.meta_data.termination_date,
  "termination_notice_date": company.meta_data.prior_notice_date,
  "termination_notice": company.meta_data.prior_notice_date != undefined,
  "unauthorization_reason_code": unauthorization_reason_code,
  "unauthorization_reason_description": unauthorization_reason_description,
}));</bpmn:script>
    </bpmn:scriptTask>
