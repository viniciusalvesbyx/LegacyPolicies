    <bpmn:scriptTask id="Activity_0s5kbll" name="Preparar input_data_resolved" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1ag7ekt</bpmn:incoming>
      <bpmn:outgoing>Flow_1ivssia</bpmn:outgoing>
      <bpmn:script>const company_document_number = execution.getVariable("company_document_number");
const employer_name = execution.getVariable("employer_name");
const start_date = execution.getVariable("start_date");
const gender = execution.getVariable("gender");
const employee_number = execution.getVariable("employee_number");
const monthly_net_salary = execution.getVariable("monthly_net_salary");
const cbo_code = execution.getVariable("cbo_code");
const cbo_description = execution.getVariable("cbo_description");
const is_eligible_for_loan = execution.getVariable("is_eligible_for_loan");
const admission_date = execution.getVariable("admission_date");

let input_data_resolved = {
  "employer": {
    "document_number": company_document_number,
    "name": employer_name,
    "start_date": start_date
  },
  "borrower": {
    "gender": gender
  },
  "employee_registration": {
    "number": employee_number,
    "max_consignment_margin": Number((monthly_net_salary * 0.35).toFixed(2)),
    "cbo": {
      "code": (cbo_code !== undefined &amp;&amp; cbo_code !== null) ? String(cbo_code) : null,
      "description": cbo_description
    },
    "employment_status": is_eligible_for_loan ? "active" : "inactive",
    "admission_date": admission_date
  }
}

execution.setVariable("input_data_resolved", JSON.stringify(input_data_resolved));</bpmn:script>
    </bpmn:scriptTask>
