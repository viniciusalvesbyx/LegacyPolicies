    <bpmn:scriptTask id="Activity_177b47d2-c57b-40e0-b002-e014db3bc613" name="Calcula tempo de constituição da empresa" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1ddak7o</bpmn:incoming>
      <bpmn:outgoing>Flow_19zqqga</bpmn:outgoing>
      <bpmn:script>let start_date = execution.getVariable("employer_activity_start_date");

// Lida com o formato YYYY-MM-DD
const [yearStr, monthStr, dayStr] = start_date.split("-");
const year = parseInt(yearStr, 10);
const month = parseInt(monthStr, 10) - 1; // Date usa meses de 0 a 11
const day = parseInt(dayStr, 10);

const today = new Date();
const date = new Date(year, month, day);

let years = today.getFullYear() - date.getFullYear();
let months = today.getMonth() - date.getMonth();

let totalMonths = years * 12 + months;

if (today.getDate() &lt; date.getDate()) {
  totalMonths -= 1;
}

const formattedMonth = String(month + 1).padStart(2, "0");
const formattedDay = String(day).padStart(2, "0");

execution.setVariable("company_age_in_months", totalMonths);
execution.setVariable("legal_nature", company_data.legal_nature);
execution.setVariable("share_capital", company_data?.share_capital);
execution.setVariable("start_date", `${year}-${formattedMonth}-${formattedDay}`);</bpmn:script>
    </bpmn:scriptTask>
