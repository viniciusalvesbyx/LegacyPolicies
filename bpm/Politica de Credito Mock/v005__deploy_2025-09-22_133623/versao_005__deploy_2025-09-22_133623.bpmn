      <bpmn:script>const parseMaybeJSON = (raw, varName) =&gt; {
  if (raw == null) return null;
  if (typeof raw === "string") {
    try {
      return JSON.parse(raw);
    } catch (e) {
      throw new Error(`Falha ao fazer parse de ${varName}: ${e.message}`);
    }
  }
  return raw;
};


const result_legal_person = parseMaybeJSON(execution.getVariable("result_legal_person"), "result_legal_person");
const result_natural_person = parseMaybeJSON(execution.getVariable("result_natural_person"), "result_natural_person");
const result_cbo_data = parseMaybeJSON(execution.getVariable("result_cbo_data"), "result_cbo_data");

const identification = JSON.parse(execution.getVariable("decision_metadata_identification"));

const cnpj_blocked = execution.getVariable("company_blocked");
const installment_amount = execution.getVariable("installment_amount");
const max_amount_percent = execution.getVariable("max_amount_percent");
const profile = execution.getVariable("profile");
const registered_cnpj = execution.getVariable("registered_cnpj");
const score = execution.getVariable("score");
const type_company = execution.getVariable("type_company");

let decision = {
  "identification": identification,
  "decision": {
    "natural_person": {
      "natural_person_status": result_natural_person?.status,
      "natural_person_reason": result_natural_person?.reason,
      "profile": profile,
      "score_borrower": score,
      "dismissal_rate_by_cbo_subgroup": result_cbo_data?.dismissal_rate_by_cbo_subgroup,
      "average_employment_time_by_cbo_family": result_cbo_data?.average_employment_time_by_cbo_family,
    },
    "legal_person": {
      "legal_person_status": result_legal_person?.status,
      "legal_person_reason": result_legal_person?.reason,
      "type_company": type_company,
      "registered_cnpj": registered_cnpj,
      "cnpj_blocked": cnpj_blocked,
    },
    "credit_terms_conditions": {
      "max_amount_percent": max_amount_percent,
      "installment_amount": Math.round(installment_amount),
    }
  }
};
 
execution.setVariable("decision_metadata", JSON.stringify(decision));</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_f0b1b6e0-2ae4-4111-98d1-a3e75cacd2b" name="Preparar retorno" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1ivssia</bpmn:incoming>
      <bpmn:outgoing>Flow_0w5aaxk</bpmn:outgoing>
      <bpmn:script>// Função auxiliar para parsear variáveis que podem ser string ou objeto
const parseMaybeJSON = (raw, varName) =&gt; {
  if (raw == null) return null;
  if (typeof raw === "string") {
    try {
      return JSON.parse(raw);
    } catch (e) {
      throw new Error(`Falha ao fazer parse de ${varName}: ${e.message}`);
    }
  }
  return raw;
};

const sources = [
  "result_natural_person",
  "result_legal_person",
];

const results = sources.map((name) =&gt; ({
  name,
  data: parseMaybeJSON(execution.getVariable(name), name),
}));

const statuses = results.map(r =&gt; ({
  name: r.name,
  status: r.data?.status,
  reason: r.data?.reason
}));

let final_status = "ERROR";
let cancel_reason = "ERROR";

const allApproved = statuses.every(s =&gt; s.status === "approved");
const deniedOnes = statuses.filter(s =&gt; s.status === "denied");

if (allApproved) {
  final_status = "approved";
  cancel_reason = "";
} else if (deniedOnes.length &gt; 0) {
  final_status = "denied";
  cancel_reason = deniedOnes.map(s =&gt; s.reason).filter(Boolean).join(" - ");
}

const credit_terms_conditions = parseMaybeJSON(execution.getVariable("credit_terms_conditions"), "credit_terms_conditions");
const decision_metadata = parseMaybeJSON(execution.getVariable("decision_metadata"), "decision_metadata");
const document_number = execution.getVariable("document_number");
const input_data_resolved = parseMaybeJSON(execution.getVariable("input_data_resolved"), "input_data_resolved");


let jsonData = {
  "document_number": document_number,
  "status": final_status,
  "credit_terms_conditions": credit_terms_conditions,
  "decision_metadata": decision_metadata,
  "input_data_resolved": input_data_resolved
};

if (final_status === "denied") {
  jsonData["cancel_reason"] = cancel_reason;
  jsonData["credit_terms_conditions"] = null;
  delete jsonData['input_data_resolved'];
}

var Spin = org.camunda.spin.Spin;
execution.setVariable("body_result", Spin.JSON(JSON.stringify(jsonData)));</bpmn:script>
    </bpmn:scriptTask>
