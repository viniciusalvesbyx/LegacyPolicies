  <bpmn:process id="Process_3992e0e3-d261-4804-9624-1a94e74fa521" name="TESTES_AUTOMATICOS_consignado_privado" isExecutable="true" camunda:versionTag="1" camunda:historyTimeToLive="3">
    <bpmn:businessRuleTask id="Avaliacao_CPF_DMN1.1_com_restricao_PINE_BYX" name="Avaliação CPF DMN1.1.1 com restrição PINE_ BYX" camunda:resultVariable="result_natural_person" camunda:decisionRef="TESTES_AUTOMATICOS_DMN1.1.1" camunda:mapDecisionResult="singleResult">
