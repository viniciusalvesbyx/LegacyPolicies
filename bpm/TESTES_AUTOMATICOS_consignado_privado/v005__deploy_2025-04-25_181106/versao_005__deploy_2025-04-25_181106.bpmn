    <bpmn:scriptTask id="Activity_0zu84yy" name="Preparar variáveis para DMN1" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1hb159b</bpmn:incoming>
      <bpmn:outgoing>Flow_1uqngz8</bpmn:outgoing>
      <bpmn:script>let input_data = {};
try {
  const input_data_raw = execution.getVariable("input_data");
  input_data = input_data_raw ? JSON.parse(input_data_raw) : {};
} catch (error) {
  input_data = {}; // ou logar erro se preferir
}

// Setando variáveis com fallback seguro
execution.setVariable("is_eligible_for_loan", input_data?.is_eligible_for_loan ?? null);
execution.setVariable("contract_end_date", input_data?.contract_end_date ?? null);
execution.setVariable("leave_of_absense", input_data?.leave_of_absense ?? null);
execution.setVariable("termination_notice", input_data?.termination_notice ?? null);
execution.setVariable("is_pep", input_data?.is_pep ?? null);
execution.setVariable("employment_duration_in_months", input_data?.employment_duration_in_months ?? null);
execution.setVariable("company_document_number", input_data?.company_document_number ?? null);
execution.setVariable("age", input_data?.age ?? null);
execution.setVariable("gender", input_data?.gender ?? null);

</bpmn:script>
    </bpmn:scriptTask>
