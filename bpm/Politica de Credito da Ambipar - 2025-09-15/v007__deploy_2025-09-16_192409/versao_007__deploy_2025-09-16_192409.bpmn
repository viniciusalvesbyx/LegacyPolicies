    "password": "celcoin_originator_secret_id",
    "grant_type": "client_credentials",
    "path": "celcoin_auth_url"
}</camunda:inputParameter>
          <camunda:inputParameter name="timeout">60000</camunda:inputParameter>
          <camunda:inputParameter name="variable_name">response_scr</camunda:inputParameter>
