    <bpmn:scriptTask id="Activity_fe4fcf42-8389-4cce-8ead-1e6175465d44" name="Extrai Companies Documents" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_077nxu7</bpmn:incoming>
      <bpmn:outgoing>Flow_19dygmm</bpmn:outgoing>
      <bpmn:script>const response_saldo = JSON.parse(execution.getVariable("response_saldo"));
var balances = response_saldo.balances;

var company_document_numbers = [];
for (var i = 0; i &lt; balances.length; i++)
    company_document_numbers.push(balances[i].company_document_number);

execution.setVariable("company_document_numbers", JSON.stringify(company_document_numbers));</bpmn:script>
