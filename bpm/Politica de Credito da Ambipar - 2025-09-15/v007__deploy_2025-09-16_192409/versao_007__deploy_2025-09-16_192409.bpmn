    <bpmn:scriptTask id="Activity_6a2ef76e-0b3e-462c-9616-122dac745dae" name="Preparar identification" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0su6gtu</bpmn:incoming>
      <bpmn:outgoing>Flow_0wsyn7j</bpmn:outgoing>
      <bpmn:script>const parseMaybeJSON = (raw, varName) =&gt; {
  if (raw == null) return null;
  if (typeof raw === "string") {
    try {
      return JSON.parse(raw);
    } catch (e) {
      throw new Error(`Falha ao fazer parse de ${varName}: ${e.message}`);
    }
  }
  return raw;
};

const available_consignment_margin = execution.getVariable("available_consignment_margin"); 
const is_eligible_for_loan = execution.getVariable("is_eligible_for_loan");
const contract_end_date = execution.getVariable("contract_end_date");
const termination_date = execution.getVariable("termination_date");
const termination_notice = execution.getVariable("termination_notice");
const termination_notice_date = execution.getVariable("termination_notice_date");
const leave_of_absense = execution.getVariable("leave_of_absense");
const is_pep = execution.getVariable("is_pep");
const age = execution.getVariable("age");
const family_cbo_code = execution.getVariable("family_cbo_code");
const employment_duration_in_months = execution.getVariable("employment_duration_in_months");
const fgts_payment_delay_record = execution.getVariable("fgts_payment_delay_record");
const type_company = execution.getVariable("type_company");
const company_age_in_months = execution.getVariable("company_age_in_months");
const cnae = execution.getVariable("cnae");
const score = execution.getVariable("score");
const admission_date = execution.getVariable("admission_date");
const active_or_suspended_loan_count = execution.getVariable("active_or_suspended_loan_count");
const max_amount_percent = execution.getVariable("max_amount_percent");
const result_tax_values = execution.getVariable("result_tax_values");
const installment_amount = execution.getVariable("installment_amount");
const total_overdue_and_written_amount = execution.getVariable("total_overdue_and_written_amount"); 
const income_commitment_ratio = execution.getVariable("income_commitment_ratio"); 
const loan_due_amount_within_90d = execution.getVariable("loan_due_amount_within_90d"); 
const profile = execution.getVariable("profile");
const percent_income_360d = execution.getVariable("percent_income_360d");
const monthly_net_salary = execution.getVariable("monthly_net_salary");
const registered_cnpj = execution.getVariable("company_blocked") === false;

const company_data = parseMaybeJSON(execution.getVariable("company_data"), "company_data");

var identification = {
  "available_consignment_margin": available_consignment_margin,
  "is_eligible_for_loan": is_eligible_for_loan,
  "contract_end_date": contract_end_date,
  "termination_date": termination_date,
  "termination_notice": termination_notice,
  "termination_notice_date": termination_notice_date,
  "leave_of_absense": leave_of_absense,
  "is_pep": is_pep,
  "age": age,
  "family_cbo_code": family_cbo_code,
  "employment_duration_in_months": employment_duration_in_months,
  "profile": profile,
  "percent_income_360d": percent_income_360d,
  "monthly_net_salary": Math.round(monthly_net_salary),
  "fgts_payment_delay_record": fgts_payment_delay_record,
  "type_company": type_company,
  "company_age_in_months": company_age_in_months,
  "score_borrower": score,
  "max_amount_percent": max_amount_percent,
  "installment_amount": Math.round(installment_amount),
  "total_overdue_and_written_amount": total_overdue_and_written_amount,
  "income_commitment_ratio": income_commitment_ratio,
  "loan_due_amount_within_90d": Math.round(loan_due_amount_within_90d),
  "registered_cnpj": registered_cnpj
};

if(company_data) {
    let start_date = company_data.date_start;

    const year = start_date.substring(0, 4);
    const month = start_date.substring(4, 6);
    const day = start_date.substring(6, 8);

    identification["company"] = {
        "cnae_code": company_data.cnae,
        "company_size": company_data.size_company,
        "document_number": company_data.document_number,
        "has_fgts_debt": company_data.is_debt_fgts == "1",
        "legal_nature": execution.getVariable("legal_nature"),
        "share_capital": parseFloat(company_data.share_capital),
        "special_situation": company_data.situation_special,
        "start_date": year + "-" + month + "-" + day 
    };
}

var jsonString = JSON.stringify(identification); 
execution.setVariable("decision_metadata_identification", jsonString);</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_e8927d10-0d3b-4976-a853-3a9758174987" name="Preparar decision" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0wsyn7j</bpmn:incoming>
      <bpmn:outgoing>Flow_1ag7ekt</bpmn:outgoing>
      <bpmn:script>const parseMaybeJSON = (raw, varName) =&gt; {
  if (raw == null) return null;
  if (typeof raw === "string") {
    try {
      return JSON.parse(raw);
    } catch (e) {
      throw new Error(`Falha ao fazer parse de ${varName}: ${e.message}`);
    }
  }
  return raw;
};

const result_legal_person = parseMaybeJSON(execution.getVariable("result_legal_person"), "result_legal_person");
const result_natural_person = parseMaybeJSON(execution.getVariable("result_natural_person"), "result_natural_person");
const result_cbo_data = parseMaybeJSON(execution.getVariable("result_cbo_data"), "result_cbo_data");
const result_tax_values = parseMaybeJSON(execution.getVariable("result_tax_values"), "result_tax_values");

const identification = JSON.parse(execution.getVariable("decision_metadata_identification"));
const cnpj_blocked = execution.getVariable("company_blocked");
const installment_amount = execution.getVariable("installment_amount");

let decision = {
  "identification": identification,
  "decision": {
    "cnpj_blocked": cnpj_blocked,
    "natural_person_reason": result_natural_person?.reason,
    "natural_person_status": result_natural_person?.status,
    "legal_person_reason": result_legal_person?.reason,
    "legal_person_status": result_legal_person?.status,
    "installment_amount": Math.round(installment_amount),
    "dismissal_rate_by_cbo_subgroup": result_cbo_data?.dismissal_rate_by_cbo_subgroup,
    "average_employment_time_by_cbo_family": result_cbo_data?.average_employment_time_by_cbo_family,
    "max_amount_percent": result_tax_values?.max_amount_percent
  }
};
 
execution.setVariable("decision_metadata", JSON.stringify(decision));</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_f0b1b6e0-2ae4-4111-98d1-a3e75cacd2b" name="Preparar retorno" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1ivssia</bpmn:incoming>
      <bpmn:outgoing>Flow_0w5aaxk</bpmn:outgoing>
      <bpmn:script>// Função auxiliar para parsear variáveis que podem ser string ou objeto
const parseMaybeJSON = (raw, varName) =&gt; {
  if (raw == null) return null;
  if (typeof raw === "string") {
    try {
      return JSON.parse(raw);
    } catch (e) {
      throw new Error(`Falha ao fazer parse de ${varName}: ${e.message}`);
    }
  }
  return raw;
};

const sources = [
  "result_natural_person",
  "result_legal_person",
];

const results = sources.map((name) =&gt; ({
  name,
  data: parseMaybeJSON(execution.getVariable(name), name),
}));

const statuses = results.map(r =&gt; ({
  name: r.name,
  status: r.data?.status,
  reason: r.data?.reason
}));

let final_status = "ERROR";
let cancel_reason = "ERROR";

const allApproved = statuses.every(s =&gt; s.status === "approved");
const deniedOnes = statuses.filter(s =&gt; s.status === "denied");

if (allApproved) {
  final_status = "approved";
  cancel_reason = "";
} else if (deniedOnes.length &gt; 0) {
  final_status = "denied";
  cancel_reason = deniedOnes.map(s =&gt; s.reason).filter(Boolean).join(" - ");
}

const credit_terms_conditions = parseMaybeJSON(execution.getVariable("credit_terms_conditions"), "credit_terms_conditions");
const decision_metadata = parseMaybeJSON(execution.getVariable("decision_metadata"), "decision_metadata");
const document_number = execution.getVariable("document_number");
const input_data_resolved = parseMaybeJSON(execution.getVariable("input_data_resolved"), "input_data_resolved");


let jsonData = {
  "document_number": document_number,
  "status": final_status,
  "credit_terms_conditions": credit_terms_conditions,
  "decision_metadata": decision_metadata,
  "input_data_resolved": input_data_resolved
};

if (final_status === "denied") {
  jsonData["cancel_reason"] = cancel_reason;
  jsonData["credit_terms_conditions"] = null;
  delete jsonData['input_data_resolved'];
}

execution.setVariable("body_result", JSON.stringify(jsonData));</bpmn:script>
    </bpmn:scriptTask>
