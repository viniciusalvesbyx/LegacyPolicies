  <bpmn:process id="WIP_personal_income_ph3a" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_1mgmwnc</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Consult_Personal_Income_PH3A" name="Consult Personal Income PH3A" camunda:asyncAfter="true" camunda:type="external" camunda:topic="PH3ARequestPersonalIncome">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="timeout">30000</camunda:inputParameter>
          <camunda:inputParameter name="variable_name">response_personal_income_ph3A</camunda:inputParameter>
          <camunda:inputParameter name="handler_error">true</camunda:inputParameter>
          <camunda:inputParameter name="document_number">${document_number}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0gph2j5</bpmn:incoming>
      <bpmn:outgoing>Flow_1gu790l</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Proccess_Personal_Income_PH3A" name="Proccess Personal Income PH3A" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1gu790l</bpmn:incoming>
      <bpmn:outgoing>Flow_1sm7jvf</bpmn:outgoing>
      <bpmn:script>const response_personal_income_ph3A = JSON.parse(execution.getVariable("response_personal_income_ph3A"));

personal_income_ph3A = response_personal_income_ph3A.Data.Income.Personal

execution.setVariable("personal_income_ph3A", personal_income_ph3A);</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gateway_12rhm65">
      <bpmn:outgoing>Flow_0i0f9ys</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_0dvgyv6" name="Has Contract Termination">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="result_natural_person">{
  "reason": "Borrower has an active GPS contract termintation alert",
  "status": "denied"
}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0i0f9ys</bpmn:incoming>
    </bpmn:task>
    <bpmn:boundaryEvent id="Event_1vqhbp2" attachedToRef="Consult_Personal_Income_PH3A">
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1qxgko7" errorRef="Error_0gcnlk5" camunda:errorCodeVariable="errorCode" camunda:errorMessageVariable="errorMessage" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_1gu790l" sourceRef="Consult_Personal_Income_PH3A" targetRef="Proccess_Personal_Income_PH3A" />
    <bpmn:sequenceFlow id="Flow_1sm7jvf" sourceRef="Proccess_Personal_Income_PH3A" targetRef="Activity_1dbzgu1" />
    <bpmn:sequenceFlow id="Flow_0i0f9ys" sourceRef="Gateway_12rhm65" targetRef="Activity_0dvgyv6" />
    <bpmn:sequenceFlow id="Flow_1mgmwnc" sourceRef="StartEvent_1" targetRef="Activity_1kx0520" />
    <bpmn:scriptTask id="Activity_1kx0520" name="Preparar variaveis" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1mgmwnc</bpmn:incoming>
      <bpmn:outgoing>Flow_0gph2j5</bpmn:outgoing>
      <bpmn:script>const input_data_raw = execution.getVariable("input_data");
const input_data = JSON.parse(input_data_raw);

execution.setVariable("is_eligible_for_loan", input_data.is_eligible_for_loan);
execution.setVariable("contract_end_date", !input_data.contract_end_date ? false : true);
execution.setVariable("leave_of_absense", input_data.leave_of_absense);
execution.setVariable("termination_notice", input_data.termination_notice);
execution.setVariable("is_pep", input_data.is_pep);
execution.setVariable("employment_duration_in_months", input_data.employment_duration_in_months);
execution.setVariable("company_document_number", input_data.company_document_number);
execution.setVariable("age", input_data.age);
execution.setVariable("gender", input_data.gender);
execution.setVariable("available_consignment_margin", input_data.available_consignment_margin);
execution.setVariable("remuneration", parseFloat(input_data.base_margin_amount));
// execution.setVariable("active_or_suspended_loan_count", input_data.active_or_suspended_loan_count);


if (input_data &amp;&amp; input_data.cbo &amp;&amp; input_data.cbo.code) {
  const code = input_data.cbo.code.toString();

  const groupCboCode = code.slice(0, 1);
  const familyCboCode = code.slice(0, 4);

  execution.setVariable("group_cbo_code", groupCboCode);
  execution.setVariable("family_cbo_code", familyCboCode);
}
if (input_data &amp;&amp; input_data.scr) {
  execution.setVariable("scr_total_overdue_amount", input_data.scr.total_overdue_amount);
  execution.setVariable("scr_written_off_amount", input_data.scr.written_off_amount);
  execution.setVariable("scr_loan_due_amount_within_360d", input_data.scr.loan_due_amount_within_360d);
  execution.setVariable("scr_total_consignment_loan_overdue_amount", input_data.scr.total_consignment_loan_overdue_amount);
  execution.setVariable("scr_consignment_loan_written_off_amount", input_data.scr.consignment_loan_written_off_amount);
  execution.setVariable("scr_consignment_loan_due_amount", input_data.scr.consignment_loan_due_amount);
  execution.setVariable("scr_total_clean_loan_overdue_amount", input_data.scr.total_clean_loan_overdue_amount);
  execution.setVariable("scr_clean_loan_written_off_amount", input_data.scr.clean_loan_written_off_amount);
  execution.setVariable("scr_clean_loan_due_amount", input_data.scr.clean_loan_due_amount);
}</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_0gph2j5" sourceRef="Activity_1kx0520" targetRef="Consult_Personal_Income_PH3A" />
    <bpmn:endEvent id="Event_1ro1vde">
