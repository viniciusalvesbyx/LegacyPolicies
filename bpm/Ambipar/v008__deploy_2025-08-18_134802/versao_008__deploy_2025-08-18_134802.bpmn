    <bpmn:scriptTask id="Activity_07xb35r" name="Preparar CreditTermsConditions" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_16h173n</bpmn:incoming>
      <bpmn:outgoing>Flow_1flkf8j</bpmn:outgoing>
      <bpmn:script>const credit_terms_conditions = [{
    "min_total_number_of_installments": 24,
    "max_total_number_of_installments": 24,
    "min_installment_amount": 150,
    "max_installment_amount": 400.00,
    "min_disbursement_amount": 3000.00,
    "max_disbursement_amount": 20000.00, 
    "interest": {
      "interest_rate_type": "pre_fixed",
      "pre_fixed": {
        "min_monthly_rate": 0.049,
        "max_monthly_rate": 0.049,
        "interest_base": 360 
      }
    },
    "taxes": {
      "has_iof": true,
    },
    "fees": [] 
  }]

const jsonString = JSON.stringify(credit_terms_conditions); 
execution.setVariable("credit_terms_conditions", jsonString);</bpmn:script>
