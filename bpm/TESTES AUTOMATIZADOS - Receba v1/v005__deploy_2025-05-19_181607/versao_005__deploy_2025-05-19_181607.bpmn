    <bpmn:scriptTask id="Activity_0ufxuuv" name="Calcular due_date_rule" scriptFormat="JavaScript">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_1demmre</bpmn:incoming>
      <bpmn:outgoing>Flow_1doz13d</bpmn:outgoing>
      <bpmn:script>const MINIMUM_WAGE = 1518.00;

const input_data_raw = execution.getVariable("input_data");

const input_data = JSON.parse(input_data_raw); 

const benefit = input_data.benefit

const benefit_number = benefit.benefit_number;
const declared_gross_benefit_amount = benefit.declared_gross_benefit_amount;
var due_date_rule = benefit.due_date_rule;

execution.setVariable("input_data_raw", input_data_raw);

var benefit_number_penultimate_digit = benefit_number.slice(-2, -1);

var dueDateRuleUpToOneSalary = {
  "1":"reverse_fifth_business_day", 
  "2":"reverse_fourth_business_day", 
  "3":"reverse_third_business_day", 
  "4":"reverse_second_business_day", 
  "5":"reverse_first_business_day", 
  "6":"first_business_day", 
  "7":"second_business_day", 
  "8":"third_business_day", 
  "9":"fourth_business_day", 
  "0":"fifth_business_day", 
}

var dueDateRuleGreaterThanOneSalary = {
  "1":"first_business_day", 
  "2":"second_business_day", 
  "3":"third_business_day", 
  "4":"fourth_business_day", 
  "5":"fifth_business_day", 
  "6":"first_business_day", 
  "7":"second_business_day", 
  "8":"third_business_day", 
  "9":"fourth_business_day", 
  "0":"fifth_business_day", 
}


if (!due_date_rule &amp;&amp; declared_gross_benefit_amount &gt; MINIMUM_WAGE) {
  due_date_rule = dueDateRuleGreaterThanOneSalary[benefit_number_penultimate_digit];
}else if(!due_date_rule &amp;&amp; declared_gross_benefit_amount &lt;= MINIMUM_WAGE){
  due_date_rule = dueDateRuleUpToOneSalary[benefit_number_penultimate_digit];
} 


jsonData = {
  "benefit_number": benefit_number,
  "declared_gross_benefit_amount": declared_gross_benefit_amount,
  "due_date_rule": due_date_rule,
}

var jsonString = JSON.stringify(jsonData);
execution.setVariable("due_date_rule", due_date_rule);
execution.setVariable("body_result3", jsonString);</bpmn:script>
    </bpmn:scriptTask>
