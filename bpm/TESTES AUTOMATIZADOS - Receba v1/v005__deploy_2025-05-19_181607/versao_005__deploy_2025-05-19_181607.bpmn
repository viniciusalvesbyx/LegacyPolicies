    <bpmn:scriptTask id="Activity_1iji3j0" name="Preparar retorno" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_18c6u92</bpmn:incoming>
      <bpmn:outgoing>Flow_00u3uro</bpmn:outgoing>
      <bpmn:script>const input_data_raw = execution.getVariable("input_data");
const result = execution.getVariable("result");
const input_data = JSON.parse(input_data_raw); 

const due_date_rule = execution.getVariable("due_date_rule");
const commitment_ratio_percentage = execution.getVariable("commitment_ratio_percentage");
const concurrent_debts_amount = execution.getVariable("concurrent_debts_amount");
const max_first_installment_grace_period = execution.getVariable("max_first_installment_grace_period");
const min_first_installment_grace_period = execution.getVariable("min_first_installment_grace_period");

const status = result.status;
const reason = result.reason;

MONTHLY_RATE = 0.23;
TOTAL_NUMBER_OF_INSTALLMENTS = 12;
MIN_INSTALLMENT_AMOUNT = 140.0;

var identification = { }

var decision = {
    "reason": reason
}

let credit_terms_conditions = null


var jsonData = {
  "document_number": document_number, 
  "status": status, 
  "credit_terms_conditions": credit_terms_conditions,
  "decision_metadata": {
      "identification": identification,
      "decision": decision,
  }, 
  "input_data": input_data,
};

if (status == "denied"){
    jsonData["cancel_reason"] = reason
}

var jsonString = JSON.stringify(jsonData); 
execution.setVariable("body_result3", jsonString);
    </bpmn:script>
    </bpmn:scriptTask>
