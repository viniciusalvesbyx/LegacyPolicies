      <bpmn:outgoing>Flow_1sm7jvf</bpmn:outgoing>
      <bpmn:script>const response_termination = JSON.parse(execution.getVariable("response_termination"));
execution.setVariable("has_gps_termination", response_termination.existe_rescisao);

