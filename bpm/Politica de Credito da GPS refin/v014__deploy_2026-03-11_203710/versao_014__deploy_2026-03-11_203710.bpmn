    <bpmn:scriptTask id="Activity_0nq024n" name="Extrair Companies Documents" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1p8atfw</bpmn:incoming>
      <bpmn:outgoing>Flow_097rism</bpmn:outgoing>
      <bpmn:script>var response_saldo_raw = execution.getVariable("response_saldo");
const response_saldo = JSON.parse(response_saldo_raw);
var balances = response_saldo.balances;
var company_document_numbers = [];

for (var i = 0; i &lt; balances.length; i++) {
    company_document_numbers.push(balances[i].company_document_number);
}

execution.setVariable("company_document_numbers", JSON.stringify(company_document_numbers));</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_0kbg21y" sourceRef="Activity_1qstzby" targetRef="Activity_1qyqa4p" />
    <bpmn:scriptTask id="Activity_1qstzby" name="Prepara variaves DataPrev" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1rmrq5a</bpmn:incoming>
      <bpmn:outgoing>Flow_0kbg21y</bpmn:outgoing>
      <bpmn:script>function calcula_tempo_em_meses(start_date) {
    const year = parseInt(start_date.substring(0, 4), 10);
    const month = parseInt(start_date.substring(5, 7), 10) - 1;
    const day = parseInt(start_date.substring(8, 10), 10);
    const today = new Date();
    const date = new Date(year, month, day);
    let years = today.getFullYear() - date.getFullYear();
    let months = today.getMonth() - date.getMonth();
    let totalYears = years * 12;
    let totalMonths = totalYears + months;
    if (today.getDate() &lt; date.getDate()) {
        totalMonths -= 1;
    }
    return [years, totalMonths];
};


const HOLIDAY_ABSENCE_CODE = 15;
const response_saldo = JSON.parse(execution.getVariable("response_saldo"));
let balances = response_saldo.balances;
let company_data = execution.getVariable("company_data");
let company_document_number = company_data.document_number;
var company = null;
for (var i = 0; i &lt; balances.length; i++) {
  var item = balances[i];
  if (item.company_document_number == company_document_number) {
    company = item;
    break;
  }
}

var leave_of_absense = false;
if(company.meta_data.alerts != undefined) {
  for (var i = 0; i &lt; company.meta_data.alerts.length; i++) {
    var item = company.meta_data.alerts[i];
    if (item.absence_reason_code != undefined &amp;&amp; item.absence_reason_code &gt; 0 &amp;&amp; item.absence_reason_code != HOLIDAY_ABSENCE_CODE) {
      leave_of_absense = true;
      break;
    }
  }
}

var person_data = execution.getVariable("person_data");
const admission_date = person_data.admission_date;

// var employment_duration = calcula_tempo_em_meses(company.meta_data.admission_date); //DATAPREV
var employment_duration = calcula_tempo_em_meses(admission_date);

var age = calcula_tempo_em_meses(company.meta_data.birth_date);

const unauthorization_reason_code = company?.meta_data?.unauthorization_reason?.code;
const reasonMap = {
  1: "Legacy loan registered in eSocial",
  2: "Legacy loan reported by the financial institution",
  3: "Compensation amount set to zero",
  4: "Employment relationship with termination date",
  5: "No compensation in the last period",
  6: "Invalid labor regime",
  7: "Invalid worker category"
};

let unauthorization_reason_description = null;
if (unauthorization_reason_code !== undefined &amp;&amp; unauthorization_reason_code !== null) {
  unauthorization_reason_description = reasonMap[unauthorization_reason_code] || "Unknown reason";
}

execution.setVariable("admission_date_dataprev", company.meta_data.admission_date); //dataprev
execution.setVariable("admission_date_whitelist", admission_date); //whitelist
execution.setVariable("age", age[0]);
execution.setVariable("available_consignment_margin", company.products[0].available_balance);
execution.setVariable("birth_date", company.meta_data.birth_date);
execution.setVariable("cbo_code", company.meta_data.job_code.code);
execution.setVariable("cbo_description", company.meta_data.job_code.description);
execution.setVariable("company_document_number", company_document_number);
execution.setVariable("contract_end_date", company.meta_data.termination_date != undefined);
execution.setVariable("employee_number", company.employee.code);
execution.setVariable("employer_name", company.employer.name);
execution.setVariable("employment_duration_in_months", employment_duration[1]);
execution.setVariable("gender", company.meta_data.gender.code == 1 ? "male" : "female");
execution.setVariable("is_eligible_for_loan", company.products[0].authorization.details[0].authorized);
execution.setVariable("is_pep", company.meta_data.politically_exposed_person != undefined &amp;&amp; company.meta_data.politically_exposed_person.code != 0);
execution.setVariable("leave_of_absense", leave_of_absense);
execution.setVariable("monthly_net_salary", company.meta_data.base_margin_value);
execution.setVariable("mother_name", company.meta_data.mother_name);
execution.setVariable("termination_date", company.meta_data.termination_date);
execution.setVariable("termination_notice_date", company.meta_data.prior_notice_date);
execution.setVariable("termination_notice", company.meta_data.prior_notice_date != undefined);
execution.setVariable("unauthorization_reason_code", unauthorization_reason_code);
execution.setVariable("unauthorization_reason_description", unauthorization_reason_description);
execution.setVariable("total_earnings", parseFloat(company.meta_data.total_earnings));
execution.setVariable("active_or_suspended_loan_count", company.meta_data.amount_loans_assets_suspended);
let startDate = null;
if (company &amp;&amp; company.meta_data &amp;&amp; company.meta_data.employer_activity_start_date) {
  startDate = company.meta_data.employer_activity_start_date;
} else {
  // Se não existir, usa a data de hoje em YYYY-MM-DD
  const today = new Date();
  startDate = today.toISOString().split("T")[0];
}
execution.setVariable("start_date", startDate);</bpmn:script>
    </bpmn:scriptTask>
