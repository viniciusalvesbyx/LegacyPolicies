    <bpmn:serviceTask id="Activity_0k6nkgs" name="Consult absence GPS" camunda:asyncAfter="true" camunda:type="external" camunda:topic="RestGetApi">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="url">https://portalws.gpssa.com.br/srh_api/api/externo/existe-afastamento?cpf=${document_number}</camunda:inputParameter>
          <camunda:inputParameter name="headers">{
    "api-key": "a8916e23-3d9c-4332-8460-b4ee60107d05",
    "Accept": "application/json"
}</camunda:inputParameter>
          <camunda:inputParameter name="timeout">60000</camunda:inputParameter>
          <camunda:inputParameter name="variable_name">response_gps_absence</camunda:inputParameter>
          <camunda:inputParameter name="handler_error">true</camunda:inputParameter>
          <camunda:inputParameter name="log_reponse">true</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_07wq4ke</bpmn:incoming>
      <bpmn:outgoing>Flow_1rw4ol6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Proccess_Absence_Response" name="Proccess Absence Response" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1rw4ol6</bpmn:incoming>
      <bpmn:outgoing>Flow_1ig8qgg</bpmn:outgoing>
      <bpmn:script>// Interpretação de Motivo de Afastamento (Dataprev)

const response_gps_absence = JSON.parse(execution.getVariable("response_gps_absence"));

// Boolean original do Dataprev
var hasAbsence = !!response_gps_absence.existe_afastamento;

// Tenta ler o código do motivo de afastamento em diferentes campos possíveis
// Ajuste aqui se a API estiver usando outro nome de atributo
var reason =
  response_gps_absence.absence_reason_code ||   // nome esperado originalmente
  response_gps_absence.absence_Reason_Code ||   // variação que você quer testar
  response_gps_absence.motivoAfastamento ||     // exemplo de outro possível nome
  null;

// Regra MVP:
// - Se NÃO houver afastamento  -&gt; has_gps_absence = false
// - Se houver afastamento:
//     - Se reason == 15 (férias) -&gt; has_gps_absence = false (permitir fluxo)
//     - Se reason != 15          -&gt; has_gps_absence = true  (reprovar)
var hasGpsAbsence = false;

if (hasAbsence) {
  if (reason == 15) {
    hasGpsAbsence = false; // férias não bloqueiam
  } else {
    hasGpsAbsence = true;  // qualquer outro motivo bloqueia
  }
} else {
  hasGpsAbsence = false;   // sem afastamento
}

// Grava a variável de decisão usada pelo gateway
execution.setVariable("has_gps_absence", hasGpsAbsence);

// Grava o código do motivo em uma variável de contexto para políticas e auditoria
// (nome conforme especificação da Task 699)
execution.setVariable("absenceReasonCode", reason);</bpmn:script>
    </bpmn:scriptTask>
