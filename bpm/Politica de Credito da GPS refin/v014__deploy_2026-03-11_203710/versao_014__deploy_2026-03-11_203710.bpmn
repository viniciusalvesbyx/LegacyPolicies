    <bpmn:scriptTask id="Activity_0fg11nx" name="Preparar identification" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_114unwm</bpmn:incoming>
      <bpmn:outgoing>Flow_0z7mndg</bpmn:outgoing>
      <bpmn:script>const has_gps_absence = execution.getVariable("has_gps_absence");
const has_gps_termination = execution.getVariable("has_gps_termination");
const active_or_suspended_loan_count = execution.getVariable("active_or_suspended_loan_count");
const written_off_amount = execution.getVariable("written_off_amount");
const overdue_amount_over_14_days = execution.getVariable("overdue_amount_over_14_days");
const admission_date_dataprev = execution.getVariable("admission_date_dataprev");
const admission_date_whitelist = execution.getVariable("admission_date_whitelist");
const age = execution.getVariable("age");
const available_consignment_margin = execution.getVariable("available_consignment_margin");
const birth_date = execution.getVariable("birth_date");
const company_age_in_months = execution.getVariable("company_age_in_months");
const contract_end_date = execution.getVariable("contract_end_date");
const debt_cnt_bvscpc = execution.getVariable("debt_cnt_bvscpc");
const employer_name = execution.getVariable("employer_name");
const employment_duration_in_months = execution.getVariable("employment_duration_in_months");
const is_eligible_for_loan = execution.getVariable("is_eligible_for_loan");
const is_pep = execution.getVariable("is_pep");
const leave_of_absense = execution.getVariable("leave_of_absense");

// 👇 NOVO: código do motivo de afastamento do Dataprev
const absence_reason_code = execution.getVariable("absence_reason_code");

const monthly_net_salary = execution.getVariable("monthly_net_salary");
const mother_name = execution.getVariable("mother_name");
const profile = execution.getVariable("profile");
const public_tax_debt = execution.getVariable("public_tax_debt");
const reserved_available_margin = execution.getVariable("reserved_available_margin");
const score_bv = execution.getVariable("score_bv");
const total_debt_bvscpc = execution.getVariable("total_debt_bvscpc");
const unauthorization_reason_code = execution.getVariable("unauthorization_reason_code");
const unauthorization_reason_description = execution.getVariable("unauthorization_reason_description");

let company_data_raw = execution.getVariable("company_data");
let company_data;

if (typeof company_data_raw === "string") {
  try {
    company_data = JSON.parse(company_data_raw);
  } catch (e) {
    throw new Error("Falha ao fazer parse de company_data: " + e.message);
  }
} else {
  company_data = company_data_raw;
}

var identification = {
  "has_gps_absence": has_gps_absence,
  "has_gps_termination": has_gps_termination,
  "admission_date_dataprev": admission_date_dataprev,
  "admission_date_whitelist": admission_date_whitelist,
  "age": age,
  "available_consignment_margin": available_consignment_margin,
  "birth_date": birth_date,
  "contract_end_date": contract_end_date,
  "debt_cnt_bvscpc": debt_cnt_bvscpc,
  "employer_name": employer_name,
  "employment_duration_in_months": employment_duration_in_months,
  "is_eligible_for_loan": is_eligible_for_loan,
  "is_pep": is_pep,
  "leave_of_absense": leave_of_absense,

  // 👇 NOVO: campo agora visível no decision_metadata.identification
  "absence_reason_code": absence_reason_code,

  "monthly_net_salary": Math.round(monthly_net_salary),
  "active_or_suspended_loan_count": active_or_suspended_loan_count,
  "mother_name": mother_name,
  "profile": profile,
  "reserved_available_margin": reserved_available_margin,
  "score_bv": score_bv,
  "total_debt_bvscpc": total_debt_bvscpc,
  "unauthorization_reason_code": unauthorization_reason_code,
  "unauthorization_reason_description": unauthorization_reason_description,
  "scr_written_off_amount": written_off_amount,
  "scr_overdue_amount_over_14_days": overdue_amount_over_14_days
};

if (company_data) {
  identification["company"] = {
    "document_number": company_data.document_number,
    "legal_nature": company_data.legal_nature
  };
}

var jsonString = JSON.stringify(identification);
execution.setVariable("decision_metadata_identification", jsonString);</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_04akl5a" name="Preparar decision" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0z7mndg</bpmn:incoming>
      <bpmn:outgoing>Flow_1eanti6</bpmn:outgoing>
      <bpmn:script>const parseMaybeJSON = (raw, varName) =&gt; {
  if (raw == null) return null;
  if (typeof raw === "string") {
    try {
      return JSON.parse(raw);
    } catch (e) {
      throw new Error(`Falha ao fazer parse de ${varName}: ${e.message}`);
    }
  }
  return raw;
};


const result_legal_person = parseMaybeJSON(execution.getVariable("result_legal_person"), "result_legal_person");
const result_natural_person = parseMaybeJSON(execution.getVariable("result_natural_person"), "result_natural_person");

const identification = JSON.parse(execution.getVariable("decision_metadata_identification"));

const installment_amount = execution.getVariable("installment_amount");
const max_amount_percent = execution.getVariable("max_amount_percent");

let decision = {
  "identification": identification,
  "decision": {
    "natural_person_reason": result_natural_person?.reason,
    "natural_person_status": result_natural_person?.status,
    "legal_person_reason": result_legal_person?.reason,
    "legal_person_status": result_legal_person?.status,
    "max_amount_percent": max_amount_percent,
    "installment_amount": Math.round(installment_amount),
  }
};

execution.setVariable("decision_metadata", JSON.stringify(decision));</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_0ew5iwy" name="Preparar retorno" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_14zierr</bpmn:incoming>
      <bpmn:outgoing>Flow_0kah6pd</bpmn:outgoing>
      <bpmn:script>// Função auxiliar para parsear variáveis que podem ser string ou objeto
const parseMaybeJSON = (raw, varName) =&gt; {
  if (raw == null) return null;
  if (typeof raw === "string") {
    try {
      return JSON.parse(raw);
    } catch (e) {
      throw new Error(`Falha ao fazer parse de ${varName}: ${e.message}`);
    }
  }
  return raw;
};

const sources = [
  "result_natural_person",
  "result_legal_person",
];

const results = sources.map((name) =&gt; ({
  name,
  data: parseMaybeJSON(execution.getVariable(name), name),
}));

const statuses = results.map(r =&gt; ({
  name: r.name,
  status: r.data?.status,
  reason: r.data?.reason
}));

let final_status = "ERROR";
let cancel_reason = "ERROR";

const allApproved = statuses.every(s =&gt; s.status === "approved");
const deniedOnes = statuses.filter(s =&gt; s.status === "denied");

if (allApproved) {
  final_status = "approved";
  cancel_reason = "";
} else if (deniedOnes.length &gt; 0) {
  final_status = "denied";
  cancel_reason = deniedOnes.map(s =&gt; s.reason).filter(Boolean).join(" - ");
}

const credit_terms_conditions_raw = execution.getVariable("credit_terms_conditions");
let credit_terms_conditions;

if (credit_terms_conditions_raw != null) {
  try {
  credit_terms_conditions = JSON.parse(credit_terms_conditions_raw.toString());
} catch (e) {
  throw new Error("Falha ao fazer parse de credit_terms_conditions: " + e.message);
}
} else {
  credit_terms_conditions = credit_terms_conditions_raw;
}

const decision_metadata = parseMaybeJSON(execution.getVariable("decision_metadata"), "decision_metadata");
const document_number = execution.getVariable("document_number");
const input_data_resolved = parseMaybeJSON(execution.getVariable("input_data_resolved"), "input_data_resolved");


let jsonData = {
  "document_number": document_number,
  "status": final_status,
  "credit_terms_conditions": credit_terms_conditions,
  "decision_metadata": decision_metadata,
  "input_data_resolved": input_data_resolved
};

if (final_status === "denied") {
  jsonData["cancel_reason"] = cancel_reason;
  jsonData["credit_terms_conditions"] = null;
  delete jsonData['input_data_resolved'];
}

var Spin = org.camunda.spin.Spin;
execution.setVariable("body_result", Spin.JSON(JSON.stringify(jsonData)));</bpmn:script>
    </bpmn:scriptTask>
