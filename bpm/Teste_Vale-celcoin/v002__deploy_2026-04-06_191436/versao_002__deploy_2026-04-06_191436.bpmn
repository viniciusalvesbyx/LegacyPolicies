    <bpmn:scriptTask id="Activity_1rabns2" name="Transformar CNPJ 8 dígitos" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1cmo6nx</bpmn:incoming>
      <bpmn:outgoing>Flow_0gplfmf</bpmn:outgoing>
      <bpmn:script>// Função para calcular os dígitos verificadores do CNPJ
function calculateCnpjCheckDigits(baseNumber, branch = '0001') {
  baseNumber = baseNumber.toString().padStart(8, '0');
  branch = branch.toString().padStart(4, '0');

  const cnpjWithoutDigits = baseNumber + branch;

  const weights1 = [5, 4, 3, 2, 9, 8, 7, 6, 5, 4, 3, 2];
  let sum = 0;
  for (let i = 0; i &lt; weights1.length; i++) {
    sum += parseInt(cnpjWithoutDigits[i]) * weights1[i];
  }
  const remainder1 = sum % 11;
  const checkDigit1 = remainder1 &lt; 2 ? 0 : 11 - remainder1;

  const cnpjWithFirstDigit = cnpjWithoutDigits + checkDigit1;
  const weights2 = [6, 5, 4, 3, 2, 9, 8, 7, 6, 5, 4, 3, 2];
  sum = 0;
  for (let i = 0; i &lt; weights2.length; i++) {
    sum += parseInt(cnpjWithFirstDigit[i]) * weights2[i];
  }
  const remainder2 = sum % 11;
  const checkDigit2 = remainder2 &lt; 2 ? 0 : 11 - remainder2;

  const fullCnpj = cnpjWithFirstDigit + checkDigit2;
  return { numericCnpj: fullCnpj };
}

// Lógica de transformação da variável no Camunda
const rawCnpj = execution.getVariable("company_document_number");
const numericOnly = rawCnpj?.replace(/\D/g, ''); // remove pontos, barras, traços etc.

if (numericOnly &amp;&amp; numericOnly.length === 8) {
  const { numericCnpj } = calculateCnpjCheckDigits(numericOnly);
  execution.setVariable("company_document_number", numericCnpj);
}</bpmn:script>
    </bpmn:scriptTask>
