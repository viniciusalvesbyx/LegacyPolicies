    <bpmn:scriptTask id="Activity_07xb35r" name="Preparar CreditTermsConditions" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0xr86p4</bpmn:incoming>
      <bpmn:outgoing>Flow_1flkf8j</bpmn:outgoing>
      <bpmn:script>VALE_ASSURANT_INSURANCE_KEY = "8fad9ac2-21dc-47b1-9829-3b32fbb60559"

const available_consignment_margin = execution.getVariable("available_consignment_margin");
const monthly_net_salary = execution.getVariable("monthly_net_salary");
const age = execution.getVariable("age");
const employment_duration_in_months = execution.getVariable("employment_duration_in_months");

var credit_terms_conditions = [];
var cancel_reason = "";

const result_tax_values = execution.getVariable("result_tax_values");
const max_amount_percent = execution.getVariable("use_margin_percent");

let reserved_available_margin = Math.round((monthly_net_salary * 0.35 * (1 - max_amount_percent))*100)/100;
let installment_amount = Math.round((available_consignment_margin - reserved_available_margin)*100)/100;
var min_installment_amount;

result_tax_values.forEach(tax =&gt; {
  let max_total_number_of_installments = tax.max_total_installments;
  var final_age = age + tax.max_total_installments / 12;
  if (final_age &gt; 66) {
    max_total_number_of_installments = (66 - age)*12
  }
  min_installment_amount = tax.min_installment_amount;
  const conditions = {
    "min_total_number_of_installments": tax.min_total_installments,
    "max_total_number_of_installments": max_total_number_of_installments,
    "min_installment_amount": min_installment_amount,
    "max_installment_amount": installment_amount ? installment_amount : 0,
    "min_disbursement_amount": tax.min_disbursement_amount,
    "max_disbursement_amount": tax.max_disbursement_amount, 
    "interest": {
      "interest_rate_type": "pre_fixed",
      "pre_fixed": {
        "min_monthly_rate": tax.interest_rate,
        "max_monthly_rate": tax.interest_rate,
        "interest_base": 360 
      }
    },
    "taxes": {
      "has_iof": true,
    },
    "fees": []
  };

  const conditions_insurance = {
    "min_total_number_of_installments": tax.min_total_installments,
    "max_total_number_of_installments": max_total_number_of_installments,
    "min_installment_amount": min_installment_amount,
    "max_installment_amount": installment_amount ? installment_amount : 0,
    "min_disbursement_amount": tax.min_disbursement_amount,
    "max_disbursement_amount": tax.max_disbursement_amount, 
    "interest": {
      "interest_rate_type": "pre_fixed",
      "pre_fixed": {
        "min_monthly_rate": tax.interest_rate,
        "max_monthly_rate": tax.interest_rate,
        "interest_base": 360 
      }
    },
    "taxes": {
      "has_iof": true,
    },
    "fees": [
        {
          "type": "insurance_fee",
          "calculation_type": "percentage",  
          "value": 0.12,
          "billing_type": "contract_amortized",
          "insurance_key": VALE_ASSURANT_INSURANCE_KEY
        }
    ]
  };

  if (installment_amount &gt;= min_installment_amount &amp;&amp; max_total_number_of_installments &gt;= tax.min_total_installments) {
    credit_terms_conditions.push(conditions);
    if (employment_duration_in_months &gt;= 12) {
        credit_terms_conditions.push(conditions_insurance);
    }
  } else if (installment_amount &lt; min_installment_amount) {
    cancel_reason =  "Calculated Installment amount &lt; min installment amount";
  } else {
    cancel_reason = "Min total number of installments exceeds max age allowed at contract end.";
  }
});

execution.setVariable("max_amount_percent", max_amount_percent)
execution.setVariable("installment_amount", installment_amount);
execution.setVariable("min_installment_amount", min_installment_amount);
execution.setVariable("reserved_available_margin", reserved_available_margin);


var result_credit_terms_conditions = {
    "status": "approved"
};

if (credit_terms_conditions.length == 0) {
    result_credit_terms_conditions = {
        "status": "denied",
        "reason": cancel_reason
    };
}

var Spin = org.camunda.spin.Spin;
execution.setVariable("credit_terms_conditions", Spin.JSON(JSON.stringify(credit_terms_conditions)));

execution.setVariable("result_credit_terms_conditions", JSON.stringify(result_credit_terms_conditions));
execution.setVariable("result_credit_terms_conditions_status", result_credit_terms_conditions.status);</bpmn:script>
    </bpmn:scriptTask>
