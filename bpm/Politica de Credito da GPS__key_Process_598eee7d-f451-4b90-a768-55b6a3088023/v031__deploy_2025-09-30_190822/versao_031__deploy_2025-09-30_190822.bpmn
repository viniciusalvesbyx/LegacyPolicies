    <bpmn:scriptTask id="Activity_0u5b7o7" name="Preparar consulta SCR" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1hfo1ym</bpmn:incoming>
      <bpmn:outgoing>Flow_0cs9mtg</bpmn:outgoing>
      <bpmn:script>const document_number = execution.getVariable("document_number");
const credit_terms_key = execution.getVariable("credit_terms_key");
const session_id = execution.getVariable("session_id");

var authorization_raw = {
    session_id: session_id,
    credit_terms_key: credit_terms_key
};

var jsonString = JSON.stringify(authorization_raw);

var Base64 = Java.type("java.util.Base64");
var Charset = Java.type("java.nio.charset.Charset");

var utf8 = Charset.forName("UTF-8");
var byteArray = utf8.encode(jsonString).array();
var autorization_base64 = Base64.getEncoder().encodeToString(byteArray);

var now = new Date();
var year = now.getFullYear();
var month = now.getMonth() - 1;
if (month &lt; 10) {
  month = "0" + month;
}

var formattedDate = year + "-" + month;

var jsonData = {
    "evidence": autorization_base64,
    "taxpayer_id": document_number,
    "reference_date": formattedDate
};

var jsonString = JSON.stringify(jsonData); 
execution.setVariable("body_request_scr", jsonString);</bpmn:script>
    </bpmn:scriptTask>
