    <bpmn:serviceTask id="Activity_0xt8imx" name="Consulta BV SCPC" camunda:asyncAfter="true" camunda:type="external" camunda:topic="BoaVistaPostRequest" camunda:taskPriority="100">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="body">${body_request_bvscpc}</camunda:inputParameter>
          <camunda:inputParameter name="timeout">60000</camunda:inputParameter>
          <camunda:inputParameter name="variable_name">response_bvscpc</camunda:inputParameter>
          <camunda:inputParameter name="handler_error">false</camunda:inputParameter>
          <camunda:inputParameter name="log_reponse">true</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0zev6bm</bpmn:incoming>
      <bpmn:outgoing>Flow_0702vgh</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Event_02f6x7v" attachedToRef="Activity_0xt8imx">
      <bpmn:outgoing>Flow_18ht99i</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_0qoenpg" errorRef="Error_1ezxayc" camunda:errorCodeVariable="errorCode" camunda:errorMessageVariable="errorMessage" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0zev6bm" sourceRef="Activity_1xdwuex" targetRef="Activity_0xt8imx" />
    <bpmn:scriptTask id="Activity_0gp0ik2" name="Preparar variaveis BV SCPC" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_0702vgh</bpmn:incoming>
      <bpmn:outgoing>Flow_1013j6w</bpmn:outgoing>
      <bpmn:script>const response_bvscpc = JSON.parse(execution.getVariable("response_bvscpc"));

function parseBrazilianNumber(str) {
  let cleaned = str.replace(/\./g, "");
  cleaned = cleaned.replace(",", ".");
  return parseFloat(cleaned);
}

const summary_raw = response_bvscpc.data.resumoRegistroDebitosScpc;
const summary = (summary_raw &amp;&amp; summary_raw.length &gt; 0) ? summary_raw[0] : {};

execution.setVariable("total_debt_bvscpc", parseBrazilianNumber(summary.valorTotal || "0"));
execution.setVariable("debt_cnt_bvscpc", summary.totalDebitosDevedor || 0);</bpmn:script>
    </bpmn:scriptTask>
